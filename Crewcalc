<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Photon Schedule Lab</title>
  <style>
    :root{
      --card:#ffffff;
      --navy:#0f172a;
      --navy-2:#1e293b;
      --blue:#3b82f6;
      --blue-50:#eff6ff;
      --slate-50:#f8fafc;
      --slate-100:#f1f5f9;
      --slate-200:#e2e8f0;
      --slate-300:#cbd5e1;
      --slate-400:#94a3b8;
      --slate-500:#64748b;
      --slate-700:#334155;
      --green-50:#f0fdf4;
      --green-200:#bbf7d0;
      --green-800:#166534;
      --amber-50:#fff7ed;
      --amber-200:#fed7aa;
      --amber-800:#c2410c;
      --red-50:#fef2f2;
      --red-200:#fecaca;
      --red-800:#b91c1c;
      --shadow:0 10px 30px rgba(15,23,42,0.08);
    }

    *{box-sizing:border-box;}
    body{
      margin:0;
      font-family:Inter,Arial,sans-serif;
      background:var(--slate-100);
      color:var(--navy);
      padding:16px;
    }

    .topbar{
      background:var(--navy);
      border:1px solid var(--navy-2);
      border-radius:18px;
      padding:16px 18px;
      margin-bottom:16px;
    }

    .title{
      color:#fff;
      font-size:22px;
      font-weight:900;
      text-transform:uppercase;
      line-height:1;
    }

    .subtitle{
      color:#93c5fd;
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      margin-top:6px;
      line-height:1.45;
    }

    .layout{
      display:grid;
      grid-template-columns:420px minmax(0,1fr);
      gap:16px;
      align-items:start;
    }

    .panel{
      background:var(--card);
      border:1px solid var(--slate-200);
      border-radius:20px;
      box-shadow:var(--shadow);
      overflow:hidden;
    }

    .panel-head{
      background:var(--navy);
      padding:14px 16px;
      border-bottom:1px solid var(--navy-2);
    }

    .panel-title{
      color:#fff;
      font-size:12px;
      font-weight:900;
      text-transform:uppercase;
    }

    .panel-subtitle{
      color:#93c5fd;
      font-size:10px;
      font-weight:800;
      text-transform:uppercase;
      margin-top:4px;
    }

    .panel-body{padding:16px;}

    .section{
      border:1px solid var(--slate-200);
      border-radius:16px;
      padding:14px;
      background:var(--slate-50);
    }

    .section + .section{margin-top:14px;}

    .section-title{
      font-size:11px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--navy);
      margin-bottom:12px;
    }

    .mini-label{
      display:block;
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--slate-400);
      margin-bottom:6px;
      line-height:1.35;
    }

    .field{
      width:100%;
      border:1.5px solid var(--slate-300);
      border-radius:10px;
      padding:11px 12px;
      font-size:14px;
      font-weight:700;
      outline:none;
      background:#fff;
      color:var(--navy);
    }

    .field:focus{
      border-color:var(--blue);
      box-shadow:0 0 0 3px rgba(59,130,246,0.08);
    }

    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
    .summary-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;}

    .summary-card{
      background:#fff;
      border:1px solid var(--slate-200);
      border-radius:16px;
      padding:16px;
      min-height:118px;
    }

    .summary-label{
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--slate-400);
      margin-bottom:8px;
      line-height:1.35;
    }

    .summary-value{
      font-size:28px;
      font-weight:900;
      color:var(--navy);
      line-height:1;
    }

    .summary-sub{
      font-size:10px;
      font-weight:800;
      text-transform:uppercase;
      color:var(--slate-500);
      margin-top:8px;
      line-height:1.35;
    }

    .toolbar{display:flex;gap:10px;flex-wrap:wrap;}

    .action-btn{
      height:42px;
      border-radius:10px;
      border:1px solid var(--slate-300);
      background:#fff;
      color:var(--slate-700);
      padding:0 14px;
      font-size:11px;
      font-weight:900;
      text-transform:uppercase;
      cursor:pointer;
    }

    .action-btn.primary{
      background:var(--blue);
      border-color:#2563eb;
      color:#fff;
    }

    .document-block{
      background:#fff;
      border:1px solid var(--slate-200);
      border-radius:16px;
      padding:14px;
    }

    .document-block + .document-block{margin-top:12px;}

    .document-heading{
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--slate-400);
      margin-bottom:8px;
    }

    .document-lines{display:grid;gap:6px;}

    .document-line{
      font-size:11px;
      font-weight:800;
      color:var(--slate-700);
      line-height:1.5;
    }

    .validation-list{display:grid;gap:8px;margin-top:12px;}
    .validation-item{border-radius:12px;padding:10px 12px;font-size:11px;font-weight:800;text-transform:uppercase;line-height:1.4;}
    .validation-ok{background:var(--green-50);border:1px solid var(--green-200);color:var(--green-800);}
    .validation-warn{background:var(--amber-50);border:1px solid var(--amber-200);color:var(--amber-800);}
    .validation-error{background:var(--red-50);border:1px solid var(--red-200);color:var(--red-800);}

    .planner-shell{border:1px solid var(--slate-200);border-radius:16px;background:var(--slate-50);padding:14px;}
    .planner-row{border:1px solid var(--slate-200);border-radius:14px;background:#fff;padding:12px;}
    .planner-row + .planner-row{margin-top:10px;}
    .planner-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:10px;}
    .planner-title{font-size:11px;font-weight:900;text-transform:uppercase;color:var(--navy);}
    .planner-grid{display:grid;grid-template-columns:1.2fr 1fr .7fr .7fr .7fr;gap:10px;}
    .planner-debug{margin-top:10px;padding-top:10px;border-top:1px solid var(--slate-200);font-size:10px;font-weight:800;text-transform:uppercase;color:var(--slate-400);line-height:1.45;}

    .note-card{
      background:var(--blue-50);
      border:1px solid #bfdbfe;
      color:#1d4ed8;
      border-radius:14px;
      padding:12px 14px;
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      line-height:1.45;
    }

    @media (max-width: 980px){
      .layout{grid-template-columns:1fr;}
      .summary-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
    }

    @media (max-width: 700px){
      .summary-grid,.grid-2,.grid-3,.planner-grid{grid-template-columns:1fr;}
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="title">Photon Schedule Lab</div>
    <div class="subtitle">Standalone calculator sandbox for testing schedule logic outside the main app</div>
  </div>

  <div class="layout">
    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">Inputs</div>
        <div class="panel-subtitle">Use presets, tweak values, test logic safely</div>
      </div>
      <div class="panel-body">
        <div class="section">
          <div class="section-title">Scenario Presets</div>
          <div class="toolbar">
            <button type="button" class="action-btn" onclick="loadPreset('domestic')">Domestic</button>
            <button type="button" class="action-btn" onclick="loadPreset('storein')">Into Store</button>
            <button type="button" class="action-btn" onclick="loadPreset('storeout')">Ex Store</button>
            <button type="button" class="action-btn" onclick="loadPreset('fullpack')">Full Pack</button>
            <button type="button" class="action-btn primary" onclick="loadPreset('blank')">Blank</button>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Move Setup</div>
          <div class="grid-2">
            <div>
              <label class="mini-label">Scenario Label</label>
              <input id="scenarioLabel" type="text" class="field" value="Domestic Baseline" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Sequence Type</label>
              <select id="sequenceType" class="field" onchange="renderLab()">
                <option value="domestic">Domestic</option>
                <option value="into-store">Into Store</option>
                <option value="ex-store">Ex Store</option>
                <option value="direct-store">Direct / Store</option>
              </select>
            </div>
            <div>
              <label class="mini-label">Packing Mode</label>
              <select id="packMode" class="field" onchange="renderLab()">
                <option value="none">No Packing</option>
                <option value="cg">CG Packing</option>
                <option value="full">Full Packing</option>
              </select>
            </div>
            <div>
              <label class="mini-label">Store Load Variant</label>
              <select id="storeLoadVariant" class="field" onchange="renderLab()">
                <option value="standard">Standard</option>
                <option value="slower">Slower Store Handling</option>
                <option value="faster">Faster Store Handling</option>
              </select>
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Volume Inputs</div>
          <div class="grid-2">
            <div>
              <label class="mini-label">Furniture Volume (CUFT)</label>
              <input id="furnitureVol" type="number" min="0" class="field" value="600" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Loft Effects Volume (CUFT)</label>
              <input id="loftVol" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Loading Rate (CUFT / Man-Hour)</label>
              <input id="loadRate" type="number" min="1" class="field" value="125" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Unloading Rate (CUFT / Man-Hour)</label>
              <input id="unloadRate" type="number" min="1" class="field" value="132" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Transit Hours</label>
              <input id="transitHours" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Transit Minutes</label>
              <input id="transitMinutes" type="number" min="0" max="59" class="field" value="30" oninput="renderLab()" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Box Totals</div>
          <div class="grid-3">
            <div>
              <label class="mini-label">AP</label>
              <input id="qty_ap" type="number" min="0" class="field" value="20" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">CG</label>
              <input id="qty_cg" type="number" min="0" class="field" value="6" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Books</label>
              <input id="qty_books" type="number" min="0" class="field" value="12" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Linen</label>
              <input id="qty_linen" type="number" min="0" class="field" value="8" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">WR</label>
              <input id="qty_wr" type="number" min="0" class="field" value="4" oninput="renderLab()" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Special Labour</div>
          <div class="grid-3">
            <div>
              <label class="mini-label">Beds</label>
              <input id="svc_beds" type="number" min="0" class="field" value="2" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Bunk Beds</label>
              <input id="svc_bunk" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Custom Minutes (Each Side)</label>
              <input id="svc_custom_minutes" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Custom Note</label>
              <input id="svc_custom_note" type="text" class="field" value="" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Upright Pianos</label>
              <input id="svc_upright" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Baby / Grand Pianos</label>
              <input id="svc_grand" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Grandfather Clocks</label>
              <input id="svc_clock" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Appliances</label>
              <input id="svc_appliance" type="number" min="0" class="field" value="2" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Crating</label>
              <input id="svc_crate" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Dismantles</label>
              <input id="svc_dismantle" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Export Wrap Volume (CUFT)</label>
              <input id="exportWrapVol" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Manual Planner</div>
          <div class="planner-shell">
            <div class="toolbar" style="margin-bottom:12px;">
              <button type="button" class="action-btn" onclick="addPlannerRow()">Add Planner Day</button>
              <button type="button" class="action-btn" onclick="resetPlannerRows()">Reset Planner</button>
            </div>
            <div id="plannerRows"></div>
          </div>
        </div>

        <div class="note-card">
          Use this file to experiment with store logic, load-rate variations and validation rules before copying final calculator functions back into Photon.
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">Live Results</div>
        <div class="panel-subtitle">Mirror the main app, then adjust logic here first</div>
      </div>
      <div class="panel-body">
        <div class="summary-grid">
          <div class="summary-card">
            <div class="summary-label">Packing Mode</div>
            <div class="summary-value" id="summaryMode">—</div>
            <div class="summary-sub">No packing, CG, or full</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Total Volume</div>
            <div class="summary-value" id="summaryTotalVolume">0</div>
            <div class="summary-sub">Furniture + box volume</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Packing Man Hrs</div>
            <div class="summary-value" id="summaryPackHours">0.00</div>
            <div class="summary-sub">Cartons only</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Packing Man Days</div>
            <div class="summary-value" id="summaryPackDays">0.0</div>
            <div class="summary-sub">Based on 8 hours</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Special Labour Hrs</div>
            <div class="summary-value" id="summarySpecialHours">0.00</div>
            <div class="summary-sub">Load + unload side</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Loading Man Hrs</div>
            <div class="summary-value" id="summaryLoadHours">0.00</div>
            <div class="summary-sub">Volume + load specials</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Loading Man Days</div>
            <div class="summary-value" id="summaryLoadDays">0.0</div>
            <div class="summary-sub">Based on 8 hours</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Load Completion Crew</div>
            <div class="summary-value" id="summaryLoadCompletion">0.0</div>
            <div class="summary-sub">Crew for 4-hour load window</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Unloading Man Hrs</div>
            <div class="summary-value" id="summaryUnloadHours">0.00</div>
            <div class="summary-sub">Volume + unload specials</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Unloading Man Days</div>
            <div class="summary-value" id="summaryUnloadDays">0.0</div>
            <div class="summary-sub">Based on 8 hours</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Unload Completion Crew</div>
            <div class="summary-value" id="summaryUnloadCompletion">0.0</div>
            <div class="summary-sub">Crew for 4-hour unload window</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Store Variant</div>
            <div class="summary-value" id="summaryStoreVariant">—</div>
            <div class="summary-sub">Use this to test rule changes</div>
          </div>
        </div>

        <div class="document-block" style="margin-top:12px;">
          <div class="document-heading">Current Logic Summary</div>
          <div class="document-lines" id="logicText"></div>
        </div>

        <div class="document-block">
          <div class="document-heading">Special Labour Breakdown</div>
          <div class="document-lines" id="specialText"></div>
        </div>

        <div class="document-block">
          <div class="document-heading">Scenario Notes</div>
          <div class="document-lines" id="scenarioNotes"></div>
        </div>

        <div class="validation-list" id="validationList"></div>
      </div>
    </div>
  </div>

  <script>
    const BOX_VOLUMES = { ap:4, cg:4, books:2, linen:5, wr:10 };
    const BOX_RATES = { ap:10, cg:4, books:15, linen:10, wr:8 };
    const MORNING_LOAD_RATE = 125;
    const AFTERNOON_LOAD_RATE_AFTER_AM = 55;

    let plannerRows = [];

    function round2(value){
      return Math.round((Number(value || 0) + Number.EPSILON) * 100) / 100;
    }

    function round1(value){
      return Math.round((Number(value || 0) + Number.EPSILON) * 10) / 10;
    }

    function plannerId(){
      return 'plan_' + Date.now() + '_' + Math.random().toString(36).slice(2,7);
    }

    function defaultPlannerRows(){
      return [
        { id: plannerId(), dayPart: 'Full Day', task: 'Load', men: 3, vans: 1, hours: 8, nightsOut: false }
      ];
    }

    function getNum(id){
      const el = document.getElementById(id);
      const value = parseFloat(el ? el.value : 0);
      return Number.isFinite(value) ? value : 0;
    }

    function getText(id){
      const el = document.getElementById(id);
      return el ? String(el.value || '').trim() : '';
    }

    function getPackModeLabel(packOption){
      if (packOption === 'none') return 'No';
      if (packOption === 'cg') return 'CG';
      return 'Full';
    }

    function getIncludedKeys(packOption){
      if (packOption === 'none') return [];
      if (packOption === 'cg') return ['cg'];
      return ['ap','cg','books','linen','wr'];
    }

    function getStoreLoadMultiplier(sequenceType, variant){
      if (sequenceType !== 'into-store' && sequenceType !== 'ex-store' && sequenceType !== 'direct-store') {
        return 1;
      }
      if (variant === 'slower') return 0.8;
      if (variant === 'faster') return 1.15;
      return 1;
    }

    function getState(){
      return {
        label: getText('scenarioLabel'),
        sequenceType: getText('sequenceType') || 'domestic',
        storeLoadVariant: getText('storeLoadVariant') || 'standard',
        packOption: getText('packMode') || 'none',
        furnitureVol: getNum('furnitureVol'),
        loftVol: getNum('loftVol'),
        loadRate: getNum('loadRate') || 125,
        unloadRate: getNum('unloadRate') || 132,
        transitHours: getNum('transitHours'),
        transitMinutes: getNum('transitMinutes'),
        qty: {
          ap: getNum('qty_ap'),
          cg: getNum('qty_cg'),
          books: getNum('qty_books'),
          linen: getNum('qty_linen'),
          wr: getNum('qty_wr')
        },
        boxVolumes: BOX_VOLUMES,
        special: {
          beds: getNum('svc_beds'),
          bunk: getNum('svc_bunk'),
          customMinutes: getNum('svc_custom_minutes'),
          customNote: getText('svc_custom_note'),
          upright: getNum('svc_upright'),
          grand: getNum('svc_grand'),
          clock: getNum('svc_clock'),
          appliance: getNum('svc_appliance'),
          crate: getNum('svc_crate'),
          dismantle: getNum('svc_dismantle')
        },
        exportWrapVol: getNum('exportWrapVol'),
        plannerRows: plannerRows.slice()
      };
    }

    function calcPacking(state){
      const includedKeys = getIncludedKeys(state.packOption);
      const packHours = Object.keys(BOX_RATES).reduce((sum, key) => {
        const qty = state.qty[key] || 0;
        if (!includedKeys.includes(key)) return sum;
        return sum + (qty / BOX_RATES[key]);
      }, 0);
      return {
        packHours: round2(packHours),
        packDays: round1(packHours / 8)
      };
    }

    function calcBoxVolume(state){
      return Object.keys(state.qty).reduce((sum, key) => {
        return sum + ((state.qty[key] || 0) * (state.boxVolumes[key] || 0));
      }, 0);
    }

    function calcSpecialLabour(state){
      const includedBeds = 2;
      const includedExportWrapVol = 50;
      const extraBeds = Math.max(0, state.special.beds - includedBeds);
      const extraExportWrapVol = Math.max(0, state.exportWrapVol - includedExportWrapVol);
      const transitTotalMinutes = (state.transitHours * 60) + state.transitMinutes;
      const extraTransitMinutes = Math.max(0, transitTotalMinutes - 30);

      const loadMinutes =
        (extraBeds * 15) +
        (state.special.dismantle * 15) +
        (state.special.bunk * 30) +
        (state.special.customMinutes > 0 ? state.special.customMinutes : 0) +
        (state.special.upright * 25) +
        (state.special.grand * 60) +
        (state.special.clock * 30) +
        (state.special.appliance * 30) +
        (state.special.crate * 15) +
        ((state.loftVol / 100) * 20) +
        ((extraExportWrapVol / 100) * 25);

      const unloadMinutes =
        (extraBeds * 15) +
        (state.special.bunk * 30) +
        (state.special.customMinutes > 0 ? state.special.customMinutes : 0) +
        (state.special.upright * 25) +
        (state.special.grand * 60) +
        (state.special.clock * 30) +
        (state.special.appliance * 30) +
        (state.special.crate * 15) +
        extraTransitMinutes;

      return {
        specialHours: round2((loadMinutes + unloadMinutes) / 60),
        loadSideHours: round2(loadMinutes / 60),
        unloadSideHours: round2(unloadMinutes / 60),
        extraTransitHours: round2(extraTransitMinutes / 60),
        breakdown: {
          beds: round2((extraBeds * 30) / 60),
          dismantle: round2((state.special.dismantle * 15) / 60),
          bunk: round2((state.special.bunk * 60) / 60),
          custom: round2(((state.special.customMinutes > 0 ? state.special.customMinutes * 2 : 0)) / 60),
          upright: round2((state.special.upright * 50) / 60),
          grand: round2((state.special.grand * 120) / 60),
          clock: round2((state.special.clock * 60) / 60),
          appliance: round2((state.special.appliance * 60) / 60),
          crate: round2((state.special.crate * 30) / 60),
          loft: round2(((state.loftVol / 100) * 20) / 60),
          exportWrap: round2(((extraExportWrapVol / 100) * 25) / 60),
          transit: round2(extraTransitMinutes / 60),
          includedBeds,
          includedExportWrapVol
        }
      };
    }

    function calcLoading(totalVolume, loadRate, loadSideSpecialHours, state){
      const multiplier = getStoreLoadMultiplier(state.sequenceType, state.storeLoadVariant);
      const effectiveRate = round2(loadRate * multiplier);
      const volumeHours = totalVolume / effectiveRate;
      const totalHours = volumeHours + loadSideSpecialHours;
      return {
        effectiveRate,
        hours: round2(totalHours),
        days: round1(totalHours / 8),
        completionCrew: round1(totalHours / 4),
        volumeHours: round2(volumeHours)
      };
    }

    function calcUnloading(totalVolume, unloadRate, unloadSideSpecialHours, state){
      const multiplier = state.sequenceType === 'ex-store' ? getStoreLoadMultiplier(state.sequenceType, state.storeLoadVariant) : 1;
      const effectiveRate = round2(unloadRate * multiplier);
      const volumeHours = totalVolume / effectiveRate;
      const totalHours = volumeHours + unloadSideSpecialHours;
      return {
        effectiveRate,
        hours: round2(totalHours),
        days: round1(totalHours / 8),
        completionCrew: round1(totalHours / 4),
        volumeHours: round2(volumeHours)
      };
    }

    function calcScheduleValidation(packing, loading, unloading, special, state){
      const required = {
        Pack: packing.packHours,
        Load: loading.hours,
        Unload: unloading.hours
      };

      const allocated = { Pack: 0, Load: 0, Unload: 0 };
      let sharedPackLoadPool = 0;
      let sharedLoadUnloadPool = 0;

      const groups = {};
      state.plannerRows.forEach(function(day){
        const key = day.groupId || day.id;
        if (!groups[key]) groups[key] = [];
        groups[key].push(day);
      });

      Object.values(groups).forEach(function(rows){
        const hasAmLoadish = rows.some(day => day.dayPart === 'AM' && ['Load','Pack and Load','Load and Deliver','Load and Travel'].includes(day.task));

        rows.forEach(function(day){
          const men = Number(day.men || 0);
          const hours = Number(day.hours || 0);
          const capacity = men * hours;

          switch(day.task){
            case 'Pack':
              allocated.Pack += capacity;
              break;
            case 'Unload':
            case 'Deliver and Crew Return':
              allocated.Unload += capacity;
              break;
            case 'Pack and Load':
              if (day.dayPart === 'AM') {
                sharedPackLoadPool += capacity;
              } else if (day.dayPart === 'PM' && hasAmLoadish) {
                const pmLoadHours = round2((men * hours * AFTERNOON_LOAD_RATE_AFTER_AM) / state.loadRate);
                sharedPackLoadPool += pmLoadHours;
              } else {
                sharedPackLoadPool += capacity;
              }
              break;
            case 'Load and Deliver':
              if (day.dayPart === 'AM') {
                sharedLoadUnloadPool += capacity;
              } else if (day.dayPart === 'PM' && hasAmLoadish) {
                const pmLoadHours = round2((men * hours * AFTERNOON_LOAD_RATE_AFTER_AM) / state.loadRate);
                sharedLoadUnloadPool += pmLoadHours + Math.max(0, capacity - pmLoadHours);
              } else {
                sharedLoadUnloadPool += capacity;
              }
              break;
            case 'Load':
            case 'Load and Travel': {
              let loadHoursEquivalent = capacity;
              if (day.dayPart === 'PM' && hasAmLoadish) {
                const pmVolume = men * hours * AFTERNOON_LOAD_RATE_AFTER_AM;
                loadHoursEquivalent = round2(pmVolume / state.loadRate);
              }
              allocated.Load += loadHoursEquivalent;
              break;
            }
          }
        });
      });

      const packNeedAfterDirect = Math.max(0, required.Pack - allocated.Pack);
      const packLoadPoolToPack = Math.min(sharedPackLoadPool, packNeedAfterDirect);
      allocated.Pack += packLoadPoolToPack;
      allocated.Load += Math.max(0, sharedPackLoadPool - packLoadPoolToPack);

      const loadNeedAfterPackPool = Math.max(0, required.Load - allocated.Load);
      const loadUnloadPoolToLoad = Math.min(sharedLoadUnloadPool, loadNeedAfterPackPool);
      allocated.Load += loadUnloadPoolToLoad;
      allocated.Unload += Math.max(0, sharedLoadUnloadPool - loadUnloadPoolToLoad);

      const results = [];
      ['Pack','Load','Unload'].forEach(function(task){
        const req = required[task] || 0;
        const cap = allocated[task] || 0;
        const diff = round2(cap - req);

        if (req === 0 && cap === 0) {
          results.push({ type:'ok', text:'✓ ' + task + ' not required and none allocated.' });
          return;
        }
        if (cap + 0.01 < req) {
          results.push({ type:'error', text:'✕ ' + task + ' short by ' + Math.abs(diff).toFixed(2) + ' man-hours.' });
          return;
        }
        if (diff > 0.5) {
          results.push({ type:'warn', text:'! ' + task + ' has ' + diff.toFixed(2) + ' spare man-hours allocated.' });
          return;
        }
        results.push({ type:'ok', text:'✓ ' + task + ' capacity matches requirement.' });
      });

      results.push({
        type: special.extraTransitHours > 0 ? 'warn' : 'ok',
        text: special.extraTransitHours > 0
          ? '! Transit beyond the first 30 minutes adds ' + special.extraTransitHours.toFixed(2) + ' hours to the unload side.'
          : '✓ Transit is within the first 30 minutes included allowance.'
      });

      results.push({
        type:'ok',
        text:'✓ Store variant currently changes effective rates only in this lab. Adjust here before moving rules into Photon.'
      });

      return results;
    }

    function renderPlannerRows(){
      const wrap = document.getElementById('plannerRows');
