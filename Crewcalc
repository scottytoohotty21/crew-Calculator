<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Photon Schedule Lab</title>
  <style>
    :root{
      --card:#ffffff;
      --navy:#0f172a;
      --navy-2:#1e293b;
      --blue:#3b82f6;
      --blue-50:#eff6ff;
      --slate-50:#f8fafc;
      --slate-100:#f1f5f9;
      --slate-200:#e2e8f0;
      --slate-300:#cbd5e1;
      --slate-400:#94a3b8;
      --slate-500:#64748b;
      --slate-700:#334155;
      --green-50:#f0fdf4;
      --green-200:#bbf7d0;
      --green-800:#166534;
      --amber-50:#fff7ed;
      --amber-200:#fed7aa;
      --amber-800:#c2410c;
      --red-50:#fef2f2;
      --red-200:#fecaca;
      --red-800:#b91c1c;
      --shadow:0 10px 30px rgba(15,23,42,0.08);
    }

    * { box-sizing:border-box; }

    body{
      margin:0;
      font-family:Inter, Arial, sans-serif;
      background:var(--slate-100);
      color:var(--navy);
      padding:16px;
    }

    .topbar{
      background:var(--navy);
      border:1px solid var(--navy-2);
      border-radius:18px;
      padding:16px 18px;
      margin-bottom:16px;
    }

    .title{
      color:#fff;
      font-size:22px;
      font-weight:900;
      text-transform:uppercase;
      line-height:1;
    }

    .subtitle{
      color:#93c5fd;
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      margin-top:6px;
      line-height:1.45;
    }

    .layout{
      display:grid;
      grid-template-columns:430px minmax(0,1fr);
      gap:16px;
      align-items:start;
    }

    .panel{
      background:var(--card);
      border:1px solid var(--slate-200);
      border-radius:20px;
      box-shadow:var(--shadow);
      overflow:hidden;
    }

    .panel-head{
      background:var(--navy);
      padding:14px 16px;
      border-bottom:1px solid var(--navy-2);
    }

    .panel-title{
      color:#fff;
      font-size:12px;
      font-weight:900;
      text-transform:uppercase;
    }

    .panel-subtitle{
      color:#93c5fd;
      font-size:10px;
      font-weight:800;
      text-transform:uppercase;
      margin-top:4px;
    }

    .panel-body{ padding:16px; }

    .section{
      border:1px solid var(--slate-200);
      border-radius:16px;
      padding:14px;
      background:var(--slate-50);
    }

    .section + .section{ margin-top:14px; }

    .section-title{
      font-size:11px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--navy);
      margin-bottom:12px;
    }

    .mini-label{
      display:block;
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--slate-400);
      margin-bottom:6px;
      line-height:1.35;
    }

    .field{
      width:100%;
      border:1.5px solid var(--slate-300);
      border-radius:10px;
      padding:11px 12px;
      font-size:14px;
      font-weight:700;
      outline:none;
      background:#fff;
      color:var(--navy);
    }

    .field:focus{
      border-color:var(--blue);
      box-shadow:0 0 0 3px rgba(59,130,246,0.08);
    }

    .grid-2{ display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .grid-3{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
    .summary-grid{ display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px; }

    .summary-card{
      background:#fff;
      border:1px solid var(--slate-200);
      border-radius:16px;
      padding:16px;
      min-height:118px;
    }

    .summary-label{
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--slate-400);
      margin-bottom:8px;
      line-height:1.35;
    }

    .summary-value{
      font-size:28px;
      font-weight:900;
      color:var(--navy);
      line-height:1;
    }

    .summary-sub{
      font-size:10px;
      font-weight:800;
      text-transform:uppercase;
      color:var(--slate-500);
      margin-top:8px;
      line-height:1.35;
    }

    .toolbar{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .action-btn{
      height:42px;
      border-radius:10px;
      border:1px solid var(--slate-300);
      background:#fff;
      color:var(--slate-700);
      padding:0 14px;
      font-size:11px;
      font-weight:900;
      text-transform:uppercase;
      cursor:pointer;
    }

    .action-btn.primary{
      background:var(--blue);
      border-color:#2563eb;
      color:#fff;
    }

    .action-btn.delete{
      background:var(--red-50);
      border-color:var(--red-200);
      color:var(--red-800);
    }

    .document-block{
      background:#fff;
      border:1px solid var(--slate-200);
      border-radius:16px;
      padding:14px;
    }

    .document-block + .document-block{ margin-top:12px; }

    .document-heading{
      font-size:10px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--slate-400);
      margin-bottom:8px;
    }

    .document-lines{ display:grid; gap:6px; }

    .document-line{
      font-size:11px;
      font-weight:800;
      color:var(--slate-700);
      line-height:1.5;
    }

    .validation-list{
      display:grid;
      gap:8px;
      margin-top:12px;
    }

    .validation-item{
      border-radius:12px;
      padding:10px 12px;
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      line-height:1.4;
    }

    .validation-ok{
      background:var(--green-50);
      border:1px solid var(--green-200);
      color:var(--green-800);
    }

    .validation-warn{
      background:var(--amber-50);
      border:1px solid var(--amber-200);
      color:var(--amber-800);
    }

    .validation-error{
      background:var(--red-50);
      border:1px solid var(--red-200);
      color:var(--red-800);
    }

    .status-chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 14px;
      border-radius:999px;
      font-size:12px;
      font-weight:900;
      text-transform:uppercase;
      line-height:1;
    }

    .status-green{
      background:var(--green-50);
      border:1px solid var(--green-200);
      color:var(--green-800);
    }

    .status-amber{
      background:var(--amber-50);
      border:1px solid var(--amber-200);
      color:var(--amber-800);
    }

    .status-red{
      background:var(--red-50);
      border:1px solid var(--red-200);
      color:var(--red-800);
    }

    .planner-shell{
      border:1px solid var(--slate-200);
      border-radius:16px;
      background:var(--slate-50);
      padding:14px;
    }

    .planner-row{
      border:1px solid var(--slate-200);
      border-radius:14px;
      background:#fff;
      padding:12px;
    }

    .planner-row + .planner-row{ margin-top:10px; }

    .planner-head{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-bottom:10px;
    }

    .planner-title{
      font-size:11px;
      font-weight:900;
      text-transform:uppercase;
      color:var(--navy);
    }

    .planner-grid{
      display:grid;
      grid-template-columns:1.2fr 1fr .75fr .75fr;
      gap:10px;
    }

    .planner-debug{
      margin-top:10px;
      padding-top:10px;
      border-top:1px solid var(--slate-200);
      font-size:10px;
      font-weight:800;
      text-transform:uppercase;
      color:var(--slate-400);
      line-height:1.45;
    }

    .note-card{
      background:var(--blue-50);
      border:1px solid #bfdbfe;
      color:#1d4ed8;
      border-radius:14px;
      padding:12px 14px;
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      line-height:1.45;
    }

    @media (max-width:980px){
      .layout{ grid-template-columns:1fr; }
      .summary-grid{ grid-template-columns:repeat(2,minmax(0,1fr)); }
    }

    @media (max-width:700px){
      .summary-grid,
      .grid-2,
      .grid-3,
      .planner-grid{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="title">Photon Schedule Lab</div>
    <div class="subtitle">Standalone sandbox for schedule rules before moving them back into Photon</div>
  </div>

  <div class="layout">
    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">Inputs</div>
        <div class="panel-subtitle">Sequence rules, planner, travel time and labour assumptions</div>
      </div>
      <div class="panel-body">

        <div class="section">
          <div class="section-title">Scenario Presets</div>
          <div class="toolbar">
            <button type="button" class="action-btn" onclick="loadPreset('domestic')">Domestic</button>
            <button type="button" class="action-btn" onclick="loadPreset('intoStore')">Into Store</button>
            <button type="button" class="action-btn" onclick="loadPreset('exStore')">Ex Store</button>
            <button type="button" class="action-btn" onclick="loadPreset('tightDomestic')">Tight Domestic</button>
            <button type="button" class="action-btn primary" onclick="loadPreset('blank')">Blank</button>
          </div>
        </div>

        <div class="section">
  <div class="section-title">Sequence Type</div>
  <div class="grid-2">
    <div>
      <label class="mini-label">Scenario Label</label>
      <input id="scenarioLabel" type="text" class="field" value="Domestic Test" oninput="renderLab()" />
    </div>
    <div>
      <label class="mini-label">Sequence Example</label>
      <select id="sequenceExample" class="field" onchange="handleSequenceExampleChange()">
        <option value="direct-no-pack">Direct No Pack</option>
        <option value="direct-full-pack">Direct Full Pack</option>
        <option value="into-store-no-pack">Into Store No Pack</option>
        <option value="into-store-full-pack">Into Store Full Pack</option>
        <option value="ex-store">Ex Store</option>
      </select>
    </div>
    <div>
      <label class="mini-label">Base Sequence Type</label>
      <input id="sequenceTypeDisplay" type="text" class="field" value="domestic" readonly />
    </div>
    <div>
      <label class="mini-label">Pack Mode</label>
      <input id="packModeDisplay" type="text" class="field" value="none" readonly />
    </div>
    <div>
      <label class="mini-label">Loading Variant</label>
      <select id="loadingVariant" class="field" onchange="renderLab()">
        <option value="standard">Standard</option>
        <option value="slow">Slow</option>
      </select>
    </div>
    <div>
      <label class="mini-label">Working Day Max (Hours)</label>
      <input id="workingDayHours" type="number" min="1" step="0.5" class="field" value="9.5" oninput="renderLab()" />
    </div>
  </div>
</div>

        <div class="section">
          <div class="section-title">Travel Times</div>
          <div class="grid-3">
            <div>
              <label class="mini-label">Depot → Collection (mins)</label>
              <input id="travelDepotToCollection" type="number" min="0" class="field" value="30" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Collection → Delivery (mins)</label>
              <input id="travelCollectionToDelivery" type="number" min="0" class="field" value="45" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Delivery → Depot (mins)</label>
              <input id="travelDeliveryToDepot" type="number" min="0" class="field" value="35" oninput="renderLab()" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Volume Inputs</div>
          <div class="grid-2">
            <div>
              <label class="mini-label">Furniture Volume (CUFT)</label>
              <input id="furnitureVol" type="number" min="0" class="field" value="600" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Loft Effects Volume (CUFT)</label>
              <input id="loftVol" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Unloading Rate (CUFT / Man-Hour)</label>
              <input id="unloadRate" type="number" min="1" class="field" value="132" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Transit Buffer (mins after job)</label>
              <input id="dayBufferMinutes" type="number" min="0" class="field" value="30" oninput="renderLab()" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Box Totals</div>
          <div class="grid-3">
            <div>
              <label class="mini-label">AP</label>
              <input id="qty_ap" type="number" min="0" class="field" value="20" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">CG</label>
              <input id="qty_cg" type="number" min="0" class="field" value="6" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Books</label>
              <input id="qty_books" type="number" min="0" class="field" value="12" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Linen</label>
              <input id="qty_linen" type="number" min="0" class="field" value="8" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">WR</label>
              <input id="qty_wr" type="number" min="0" class="field" value="4" oninput="renderLab()" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Special Labour</div>
          <div class="grid-3">
            <div>
              <label class="mini-label">Beds</label>
              <input id="svc_beds" type="number" min="0" class="field" value="2" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Bunk Beds</label>
              <input id="svc_bunk" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Custom Minutes (each side)</label>
              <input id="svc_custom_minutes" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Custom Note</label>
              <input id="svc_custom_note" type="text" class="field" value="" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Upright Pianos</label>
              <input id="svc_upright" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Baby / Grand Pianos</label>
              <input id="svc_grand" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Grandfather Clocks</label>
              <input id="svc_clock" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Appliances</label>
              <input id="svc_appliance" type="number" min="0" class="field" value="2" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Crating</label>
              <input id="svc_crate" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Dismantles</label>
              <input id="svc_dismantle" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
            <div>
              <label class="mini-label">Export Wrap Volume (CUFT)</label>
              <input id="exportWrapVol" type="number" min="0" class="field" value="0" oninput="renderLab()" />
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Manual Planner</div>
          <div class="planner-shell">
            <div class="toolbar" style="margin-bottom:12px;">
              <button type="button" class="action-btn" onclick="addScheduleDay()">Add Day</button>
              <button type="button" class="action-btn" onclick="resetPlannerRows()">Reset Planner</button>
            </div>
            <div id="plannerRows"></div>
          </div>
        </div>

        <div class="note-card">
          This lab is for schedule rules only. Keep changing the logic here until the results feel right, then move the final functions back into Photon.
        </div>

      </div>
    </div>

    <div class="panel">
      <div class="panel-head">
        <div class="panel-title">Live Results</div>
        <div class="panel-subtitle">Sequence rules, time fit, and explainable traffic-light output</div>
      </div>
      <div class="panel-body">

        <div class="document-block" style="margin-bottom:12px;">
          <div class="document-heading">Assessment</div>
          <div id="assessmentStatus"></div>
          <div class="document-lines" id="assessmentReasons" style="margin-top:12px;"></div>
        </div>

        <div class="summary-grid">
          <div class="summary-card">
            <div class="summary-label">Packing Mode</div>
            <div class="summary-value" id="summaryMode">—</div>
            <div class="summary-sub">No packing / CG / full</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Total Volume</div>
            <div class="summary-value" id="summaryTotalVolume">0</div>
            <div class="summary-sub">Furniture + box volume</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Packing Man Hrs</div>
            <div class="summary-value" id="summaryPackHours">0.00</div>
            <div class="summary-sub">Cartons only</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Special Labour Hrs</div>
            <div class="summary-value" id="summarySpecialHours">0.00</div>
            <div class="summary-sub">Load + unload side</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Load Man Hrs</div>
            <div class="summary-value" id="summaryLoadHours">0.00</div>
            <div class="summary-sub">Based on sequence type</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Unload Man Hrs</div>
            <div class="summary-value" id="summaryUnloadHours">0.00</div>
            <div class="summary-sub">Zero for into store</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Travel Hrs</div>
            <div class="summary-value" id="summaryTravelHours">0.00</div>
            <div class="summary-sub">Depot / collection / delivery / depot</div>
          </div>
          <div class="summary-card">
            <div class="summary-label">Total Day Hrs</div>
            <div class="summary-value" id="summaryTotalDayHours">0.00</div>
            <div class="summary-sub">Work + travel + buffer</div>
          </div>
          <div class="summary-card">
  <div class="summary-label">Overtime Hrs</div>
  <div class="summary-value" id="summaryOvertimeHours">0.00</div>
  <div class="summary-sub">Above standard 9.5 hour day</div>
</div>
        </div>

        <div class="document-block" style="margin-top:12px;">
          <div class="document-heading">Logic Summary</div>
          <div class="document-lines" id="logicText"></div>
        </div>

        <div class="document-block">
          <div class="document-heading">Special Labour Breakdown</div>
          <div class="document-lines" id="specialText"></div>
        </div>

        <div class="document-block">
          <div class="document-heading">Planner Capacity Check</div>
          <div class="document-lines" id="plannerCapacityText"></div>
        </div>

        <div class="validation-list" id="validationList"></div>

      </div>
    </div>
  </div>

  <script>
    const BOX_VOLUMES = {
      ap: 4,
      cg: 4,
      books: 2,
      linen: 5,
      wr: 10
    };

    const BOX_RATES = {
      ap: 10,
      cg: 4,
      books: 15,
      linen: 10,
      wr: 8
    };

    const DAY_PARTS = ["Full Day", "AM", "PM"];
    const TASK_OPTIONS = [
      "Pack",
      "Load",
      "Unload",
      "Pack and Load",
      "Load and Deliver",
      "Load and Travel",
      "Deliver and Crew Return"
    ];

    let plannerRows = [];

    function createId(){
      return "row_" + Date.now() + "_" + Math.random().toString(36).slice(2, 7);
    }

    function round2(value){
      return Math.round((Number(value || 0) + Number.EPSILON) * 100) / 100;
    }

    function round1(value){
      return Math.round((Number(value || 0) + Number.EPSILON) * 10) / 10;
    }

    function getNum(id){
      const el = document.getElementById(id);
      const value = parseFloat(el ? el.value : 0);
      return Number.isFinite(value) ? value : 0;
    }

    function getText(id){
      const el = document.getElementById(id);
      return el ? String(el.value || "").trim() : "";
    }

    function setInputValue(id, value){
      const el = document.getElementById(id);
      if (el) el.value = value;
    }

    function getDefaultPlannerRows(){
      return [
        {
          id: createId(),
          groupId: createId(),
          dayPart: "Full Day",
          task: "Load",
          men: 3,
          vans: 1,
          hours: 8
        }
      ];
    }

    function resetPlannerRows(){
      plannerRows = getDefaultPlannerRows();
      renderLab();
    }

    function addScheduleDay(){
      const groupId = createId();
      plannerRows.push({
        id: createId(),
        groupId: groupId,
        dayPart: "Full Day",
        task: "Load",
        men: 2,
        vans: 1,
        hours: 8
      });
      renderLab();
    }

    function removeScheduleDay(rowId){
      const row = plannerRows.find(function(item){
        return item.id === rowId;
      });

      if (!row) return;

      plannerRows = plannerRows.filter(function(item){
        return item.groupId !== row.groupId;
      });

      if (!plannerRows.length){
        plannerRows = getDefaultPlannerRows();
      }

      renderLab();
    }

    function ensurePmPair(row){
      const pairExists = plannerRows.some(function(item){
        return item.groupId === row.groupId && item.dayPart === "PM";
      });

      if (!pairExists){
        plannerRows.push({
          id: createId(),
          groupId: row.groupId,
          dayPart: "PM",
          task: "Unload",
          men: row.men,
          vans: row.vans,
          hours: 4
        });
      }
    }

    function normalizeGroup(groupId){
      const rows = plannerRows.filter(function(item){
        return item.groupId === groupId;
      });

      const hasAm = rows.some(function(item){ return item.dayPart === "AM"; });
      const hasPm = rows.some(function(item){ return item.dayPart === "PM"; });
      const hasFull = rows.some(function(item){ return item.dayPart === "Full Day"; });

      if (hasAm && !hasPm){
        const amRow = rows.find(function(item){ return item.dayPart === "AM"; });
        if (amRow) ensurePmPair(amRow);
      }

      if (hasFull && rows.length > 1){
        plannerRows = plannerRows.filter(function(item){
          return !(item.groupId === groupId && item.dayPart !== "Full Day");
        });
      }
    }

    function updatePlannerRow(id, field, value){
      plannerRows = plannerRows.map(function(row){
        if (row.id !== id) return row;

        if (field === "men" || field === "vans"){
          return { ...row, [field]: Math.max(0, Number(value) || 0) };
        }

        if (field === "dayPart"){
          const nextHours = value === "Full Day" ? 8 : 4;
          return { ...row, dayPart: value, hours: nextHours };
        }

        return { ...row, [field]: value };
      });

      const row = plannerRows.find(function(item){ return item.id === id; });

      if (row && field === "dayPart"){
        if (value === "AM"){
          const updated = plannerRows.find(function(item){ return item.id === id; });
          updated.hours = 4;
          updated.task = "Load";
          ensurePmPair(updated);
        }

        if (value === "PM"){
          const updated = plannerRows.find(function(item){ return item.id === id; });
          updated.hours = 4;
          updated.task = "Unload";

          const hasAm = plannerRows.some(function(item){
            return item.groupId === updated.groupId && item.dayPart === "AM";
          });

          if (!hasAm){
            plannerRows.push({
              id: createId(),
              groupId: updated.groupId,
              dayPart: "AM",
              task: "Load",
              men: updated.men,
              vans: updated.vans,
              hours: 4
            });
          }
        }

        if (value === "Full Day"){
          plannerRows = plannerRows.filter(function(item){
            return item.groupId !== row.groupId || item.id === row.id;
          });

          plannerRows = plannerRows.map(function(item){
            if (item.id !== row.id) return item;
            return {
              ...item,
              dayPart: "Full Day",
              hours: 8,
              task: item.task === "Unload" ? "Load and Deliver" : item.task
            };
          });
        }

        normalizeGroup(row.groupId);
      }

      renderLab();
    }

    function renderPlannerRows(){
      const wrap = document.getElementById("plannerRows");
      if (!wrap) return;

      const groups = [];
      const seen = new Set();

      plannerRows.forEach(function(row){
        if (!seen.has(row.groupId)){
          seen.add(row.groupId);
          groups.push(row.groupId);
        }
      });

      wrap.innerHTML = groups.map(function(groupId, groupIndex){
        const rows = plannerRows
          .filter(function(row){ return row.groupId === groupId; })
          .sort(function(a, b){
            const order = { "Full Day": 0, "AM": 1, "PM": 2 };
            return order[a.dayPart] - order[b.dayPart];
          });

        return rows.map(function(row, rowIndex){
          return `
            <div class="planner-row">
              <div class="planner-head">
                <div class="planner-title">Day ${groupIndex + 1}${rows.length > 1 ? ` · ${row.dayPart}` : ""}</div>
                ${rowIndex === 0 && plannerRows.length > 1 ? `<button type="button" class="action-btn delete" onclick="removeScheduleDay('${row.id}')">Delete</button>` : ""}
              </div>

              <div class="planner-grid">
                <div>
                  <label class="mini-label">Task</label>
                  <select class="field" onchange="updatePlannerRow('${row.id}','task',this.value)">
                    ${TASK_OPTIONS.map(function(opt){
                      return `<option value="${opt}" ${row.task === opt ? "selected" : ""}>${opt}</option>`;
                    }).join("")}
                  </select>
                </div>

                <div>
                  <label class="mini-label">Day Part</label>
                  <select class="field" onchange="updatePlannerRow('${row.id}','dayPart',this.value)">
                    ${DAY_PARTS.map(function(opt){
                      return `<option value="${opt}" ${row.dayPart === opt ? "selected" : ""}>${opt}</option>`;
                    }).join("")}
                  </select>
                </div>

                <div>
                  <label class="mini-label">Men</label>
                  <input type="number" min="0" class="field" value="${Number(row.men || 0)}" oninput="updatePlannerRow('${row.id}','men',this.value)" />
                </div>

                <div>
                  <label class="mini-label">Vans</label>
                  <input type="number" min="0" class="field" value="${Number(row.vans || 0)}" oninput="updatePlannerRow('${row.id}','vans',this.value)" />
                </div>
              </div>

              <div class="planner-debug">
                ${row.hours} hrs · ${Number(row.men || 0)} men · ${Number(row.vans || 0)} vans · ${Number(row.hours || 0) * Number(row.men || 0)} man-hours
              </div>
            </div>
          `;
        }).join("");
      }).join("");
    }

