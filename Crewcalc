                    <div class="summary-card">
                        <div class="summary-label">Packing Mode</div>
                        <div class="summary-value" id="summaryMode">—</div>
                        <div class="summary-sub">No packing, CG packing, or full packing</div>
                    </div>
                    <div class="summary-card">
