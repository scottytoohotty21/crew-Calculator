            <input id="unloadRate" type="number" min="1" class="field" value="132" oninput="renderAll()" />
        </div>
    </div>
</div>

                <div class="section-block">
    <div class="section-title">Box Totals</div>
    <div class="grid-2">
        <div>
            <label class="mini-label">AP (All Purpose)</label>
            <div id="qty_ap_display" class="field" style="background:#f8fafc;">0</div>
        </div>
        <div>
            <label class="mini-label">CG (China & Glassware)</label>
            <div id="qty_cg_display" class="field" style="background:#f8fafc;">0</div>
        </div>
        <div>
            <label class="mini-label">Book Cartons</label>
            <div id="qty_books_display" class="field" style="background:#f8fafc;">0</div>
        </div>
        <div>
            <label class="mini-label">Linen Cartons</label>
            <div id="qty_linen_display" class="field" style="background:#f8fafc;">0</div>
        </div>
        <div>
            <label class="mini-label">WR (Wardrobe)</label>
            <div id="qty_wr_display" class="field" style="background:#f8fafc;">0</div>
        </div>
    </div>
</div>

                

                <div class="section-block">
                    <div class="section-title">Special Labour Inputs</div>
                    <div class="grid-2">
                        <div>
                            <label class="mini-label">Frame Beds</label>
                            <input id="svc_frame" type="number" min="0" class="field" value="0" oninput="renderAll()" />
                        </div>
                        <div>
                            <label class="mini-label">Bunk Beds</label>
                            <input id="svc_bunk" type="number" min="0" class="field" value="0" oninput="renderAll()" />
                        </div>
                        <div>
                            <label class="mini-label">Custom Item Minutes (each side)</label>
                            <input id="svc_custom_minutes" type="number" min="0" class="field" value="0" oninput="renderAll()" />
                        </div>
                        <div>
                            <label class="mini-label">Custom Item Note</label>
                            <input id="svc_custom_note" type="text" maxlength="40" class="field" value="" oninput="renderAll()" />
                        </div>
                        <div>
                            <label class="mini-label">Upright Pianos</label>
                            <input id="svc_upright" type="number" min="0" class="field" value="0" oninput="renderAll()" />
                        </div>
