    function renderLab(){
      renderPlannerRows();

      const state = getState();
      const packing = calcPacking(state);
      const boxVolume = round2(calcBoxVolume(state));
      const totalVolume = round2(state.furnitureVol + boxVolume);
      const special = calcSpecialLabour(state);
      const loading = calcLoading(totalVolume, state.loadRate, special.loadSideHours, state);
      const unloading = calcUnloading(totalVolume, state.unloadRate, special.unloadSideHours, state);
      const validation = calcScheduleValidation(packing, loading, unloading, special, state);

      document.getElementById('summaryMode').textContent = getPackModeLabel(state.packOption);
      document.getElementById('summaryTotalVolume').textContent = totalVolume;
      document.getElementById('summaryPackHours').textContent = packing.packHours.toFixed(2);
      document.getElementById('summaryPackDays').textContent = packing.packDays.toFixed(1);
      document.getElementById('summarySpecialHours').textContent = special.specialHours.toFixed(2);
      document.getElementById('summaryLoadHours').textContent = loading.hours.toFixed(2);
      document.getElementById('summaryLoadDays').textContent = loading.days.toFixed(1);
      document.getElementById('summaryLoadCompletion').textContent = loading.completionCrew.toFixed(1);
      document.getElementById('summaryUnloadHours').textContent = unloading.hours.toFixed(2);
      document.getElementById('summaryUnloadDays').textContent = unloading.days.toFixed(1);
      document.getElementById('summaryUnloadCompletion').textContent = unloading.completionCrew.toFixed(1);
      document.getElementById('summaryStoreVariant').textContent = state.storeLoadVariant;

      renderDocumentLines('logicText', [
        'Scenario: ' + (state.label || 'Unnamed scenario'),
        'Sequence type: ' + state.sequenceType,
        'Packing logic: ' + (state.packOption === 'none' ? 'No packing counted.' : state.packOption === 'cg' ? 'CG cartons only count towards packing labour.' : 'All carton types count towards packing labour.'),
        'Loading effective rate: ' + loading.effectiveRate + ' cuft per man-hour.',
        'Unloading effective rate: ' + unloading.effectiveRate + ' cuft per man-hour.',
        'This lab lets you test store rate behaviour before replacing Photon calculator functions.'
      ]);

      renderDocumentLines('specialText', [
        'Beds: ' + special.breakdown.beds.toFixed(2) + ' hrs extra after first ' + special.breakdown.includedBeds + ' included.',
        'Dismantles: ' + special.breakdown.dismantle.toFixed(2) + ' hrs.',
        'Bunk beds: ' + special.breakdown.bunk.toFixed(2) + ' hrs.',
        (state.special.customNote || 'Custom item') + ': ' + special.breakdown.custom.toFixed(2) + ' hrs.',
        'Upright pianos: ' + special.breakdown.upright.toFixed(2) + ' hrs.',
        'Baby / grand pianos: ' + special.breakdown.grand.toFixed(2) + ' hrs.',
        'Grandfather clocks: ' + special.breakdown.clock.toFixed(2) + ' hrs.',
        'Appliances: ' + special.breakdown.appliance.toFixed(2) + ' hrs.',
        'Crating: ' + special.breakdown.crate.toFixed(2) + ' hrs.',
        'Loft effects: ' + special.breakdown.loft.toFixed(2) + ' hrs.',
        'Export wrap: ' + special.breakdown.exportWrap.toFixed(2) + ' hrs extra after first ' + special.breakdown.includedExportWrapVol + ' cuft included.',
        'Transit: ' + special.breakdown.transit.toFixed(2) + ' hrs beyond first 30 minutes included.'
      ]);

      renderDocumentLines('scenarioNotes', [
        'Planner rows here are only for calculator testing.',
        'Use them to check whether schedule capacity still matches the model after you adjust store logic.',
        'When the rules feel right, move the final calculation functions back into Photon.'
      ]);

      renderValidation(validation);
    }

