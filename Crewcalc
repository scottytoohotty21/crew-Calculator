                            <label class="mini-label">Baby / Grand Pianos</label>
                            <input id="svc_grand" type="number" min="0" class="field" value="0" oninput="renderAll()" />
                        </div>
                        <div>
                            <label class="mini-label">Grandfather Clocks</label>
                            <input id="svc_clock" type="number" min="0" class="field" value="0" oninput="renderAll()" />
                        </div>
                        <div>
