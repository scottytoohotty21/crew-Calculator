        });
      } else {
        items.push({
          type: "ok",
          text: "Into store: unloading requirement removed"
        });
      }

      items.push({
        type: results.totalDay.totalHours > results.state.workingDayHours ? "warn" : "ok",
        text: "Total day: " + results.totalDay.totalHours.toFixed(2) + " hrs against max " + Number(results.state.workingDayHours || 0).toFixed(2) + " hrs"
      });

      wrap.innerHTML = items.map(function(item){
