</div>

<script>
const BOX_RATES = {
    ap: 10,
    cg: 4,
    books: 15,
    linen: 10,
    wr: 8
};
const BOX_VOLUMES = {
    ap: 4,
    cg: 4,
    books: 2,
    linen: 5,
    wr: 10
};
function getPhotonFeed() {
    return {
        sequenceLabel: "Sequence 2",
        packOption: "cg",
        furnitureVol: 650,
        qty: {
            ap: 20,
            cg: 8,
            books: 12,
            linen: 5,
            wr: 4
        }
    };
}
const SPECIAL_MINUTES = {
    frame: 30,
    bunk: 60,
    
    upright: 50,
    grand: 120,
    clock: 60,
    appliance: 60,
    crate: 30
};

const MORNING_LOAD_RATE = 125;
const AFTERNOON_LOAD_RATE_AFTER_AM = 55;

const DAY_PARTS = ["Full Day", "AM", "PM"];
const TASK_OPTIONS = [
    "Pack",
    "Load",
    "Unload",
    "Pack and Load",
    "Load and Deliver",
    "Load and Travel",
    "Deliver and Crew Return"
];

let manualSchedule = [
    { id: createId(), groupId: createId(), dayPart: "Full Day", task: "Pack", men: 2, hours: 8 }
];

function createId(){
    return `day_${Date.now()}_${Math.random().toString(36).slice(2,7)}`;
}

function num(id){
    const el = document.getElementById(id);
    if (!el) return 0;
    const value = parseFloat(el.value);
    return Number.isFinite(value) && value > 0 ? value : 0;
}

function round2(value){
    return Math.round((Number(value || 0) + Number.EPSILON) * 100) / 100;
}

function round1(value){
    return Math.round((Number(value || 0) + Number.EPSILON) * 10) / 10;
}

function getPackModeLabel(packOption){
    if (packOption === "none") return "No";
    if (packOption === "cg") return "CG";
    return "Full";
}

function getIncludedKeys(packOption){
    if (packOption === "none") return [];
    if (packOption === "cg") return ["cg"];
    return ["ap", "cg", "books", "linen", "wr"];
}

function getState(){
const photonFeed = getPhotonFeed();
    return {
        packOption: photonFeed.packOption || "none",
        furnitureVol: photonFeed.furnitureVol || 0,
        loftVol: num("loftVol"),
        loadRate: num("loadRate") || 125,
        unloadRate: num("unloadRate") || 132,
        transitHours: num("transitHours"),
        transitMinutes: num("transitMinutes"),

        qty: {
            ap: photonFeed.qty.ap || 0,
            cg: photonFeed.qty.cg || 0,
            books: photonFeed.qty.books || 0,
            linen: photonFeed.qty.linen || 0,
            wr: photonFeed.qty.wr || 0
        },

        boxVolumes: BOX_VOLUMES,

        special: {
            frame: num("svc_frame"),
            bunk: num("svc_bunk"),
            customMinutes: num("svc_custom_minutes"),
            customNote: document.getElementById("svc_custom_note")
                ? document.getElementById("svc_custom_note").value.trim()
                : "",
            upright: num("svc_upright"),
            grand: num("svc_grand"),
            clock: num("svc_clock"),
            appliance: num("svc_appliance"),
            crate: num("svc_crate")
        },

        exportWrapVol: num("exportWrapVol")
    };
}

function calcPacking(state){
    const includedKeys = getIncludedKeys(state.packOption);
    const packHours = Object.keys(BOX_RATES).reduce((sum, key) => {
        const qty = state.qty[key] || 0;
        if (!includedKeys.includes(key)) return sum;
        return sum + (qty / BOX_RATES[key]);
    }, 0);
    return {
        packHours: round2(packHours),
        packDays: round1(packHours / 8)
    };
}

function calcBoxVolume(state){
    return Object.keys(state.qty).reduce((sum, key) => {
        return sum + ((state.qty[key] || 0) * (state.boxVolumes[key] || 0));
    }, 0);
}

function calcSpecialLabour(state){
    const includedFrameBeds = 2;
    const includedExportWrapVol = 50;

    const extraFrameBeds = Math.max(0, state.special.frame - includedFrameBeds);
    const extraExportWrapVol = Math.max(0, state.exportWrapVol - includedExportWrapVol);
    const transitTotalMinutes = (state.transitHours * 60) + state.transitMinutes;
    const extraTransitMinutes = Math.max(0, transitTotalMinutes - 30);

    const loadMinutes =
        (extraFrameBeds * 15) +
        (state.special.bunk * 30) +
        (state.special.customMinutes > 0 ? state.special.customMinutes : 0) +
        (state.special.upright * 25) +
        (state.special.grand * 60) +
        (state.special.clock * 30) +
        (state.special.appliance * 30) +
        (state.special.crate * 15) +
        ((state.loftVol / 100) * 20) +
        ((extraExportWrapVol / 100) * 25);

    const unloadMinutes =
        (extraFrameBeds * 15) +
        (state.special.bunk * 30) +
        (state.special.customMinutes > 0 ? state.special.customMinutes : 0) +
        (state.special.upright * 25) +
        (state.special.grand * 60) +
        (state.special.clock * 30) +
        (state.special.appliance * 30) +
        (state.special.crate * 15) +
        extraTransitMinutes;

    const totalHours = (loadMinutes + unloadMinutes) / 60;

    return {
        specialHours: round2(totalHours),
        loadSideHours: round2(loadMinutes / 60),
        unloadSideHours: round2(unloadMinutes / 60),
        extraTransitHours: round2(extraTransitMinutes / 60),
        breakdown: {
            frame: round2((extraFrameBeds * 30) / 60),
            bunk: round2((state.special.bunk * 60) / 60),
            custom: round2(((state.special.customMinutes > 0 ? state.special.customMinutes * 2 : 0)) / 60),
            upright: round2((state.special.upright * 50) / 60),
            grand: round2((state.special.grand * 120) / 60),
            clock: round2((state.special.clock * 60) / 60),
            appliance: round2((state.special.appliance * 60) / 60),
            crate: round2((state.special.crate * 30) / 60),
            loft: round2(((state.loftVol / 100) * 20) / 60),
            exportWrap: round2(((extraExportWrapVol / 100) * 25) / 60),
            transit: round2(extraTransitMinutes / 60),
            includedFrameBeds,
            includedExportWrapVol
        }
    };
}

function calcLoading(totalVolume, loadRate, loadSideSpecialHours){
    const volumeHours = totalVolume / loadRate;
    const totalHours = volumeHours + loadSideSpecialHours;
    return {
        hours: round2(totalHours),
        days: round1(totalHours / 8),
        completionCrew: round1(totalHours / 4),
        volumeHours: round2(volumeHours)
    };
}

function calcUnloading(totalVolume, unloadRate, unloadSideSpecialHours){
    const volumeHours = totalVolume / unloadRate;
    const totalHours = volumeHours + unloadSideSpecialHours;
    return {
        hours: round2(totalHours),
        days: round1(totalHours / 8),
        completionCrew: round1(totalHours / 4),
        volumeHours: round2(volumeHours)
    };
}

function optionHtml(options, selected){
    return options.map(opt => `<option value="${opt}" ${String(opt) === String(selected) ? "selected" : ""}>${opt}</option>`).join("");
}

function addScheduleDay(){
    const groupId = createId();
    manualSchedule.push({ id: createId(), groupId, dayPart: "Full Day", task: "Load", men: 2, hours: 8 });
    renderAll();
}

function removeScheduleDay(id){
    if (manualSchedule.length <= 1) return;
    const row = manualSchedule.find(day => day.id === id);
    if (!row) return;
    manualSchedule = manualSchedule.filter(day => day.groupId !== row.groupId);
    if (manualSchedule.length === 0){
        manualSchedule = [{ id: createId(), groupId: createId(), dayPart: "Full Day", task: "Pack", men: 2, hours: 8 }];
    }
    renderAll();
}

function ensurePmPair(row){
    const pairExists = manualSchedule.some(day => day.groupId === row.groupId && day.dayPart === "PM");
    if (!pairExists){
        manualSchedule.push({
            id: createId(),
            groupId: row.groupId,
            dayPart: "PM",
            task: "Unload",
            men: row.men,
            hours: 4
        });
    }
}

function normalizeGroup(groupId){
    const rows = manualSchedule.filter(day => day.groupId === groupId);
    const hasAm = rows.some(day => day.dayPart === "AM");
    const hasPm = rows.some(day => day.dayPart === "PM");
    const hasFull = rows.some(day => day.dayPart === "Full Day");

    if (hasAm && !hasPm){
        const amRow = rows.find(day => day.dayPart === "AM");
        ensurePmPair(amRow);
    }

    if (hasFull && rows.length > 1){
        manualSchedule = manualSchedule.filter(day => !(day.groupId === groupId && day.dayPart !== "Full Day"));
    }
}

function updateScheduleDay(id, field, value){
    manualSchedule = manualSchedule.map(day => {
        if (day.id !== id) return day;
        if (field === "men" || field === "hours") {
            return { ...day, [field]: Math.max(0, Number(value) || 0) };
        }
        return { ...day, [field]: value };
    });

    const row = manualSchedule.find(day => day.id === id);
    if (row && field === "dayPart"){
        if (value === "AM"){
            const updated = manualSchedule.find(day => day.id === id);
            updated.hours = 4;
            updated.task = "Load";
            ensurePmPair(updated);
        }
        if (value === "PM"){
            const updated = manualSchedule.find(day => day.id === id);
            updated.hours = 4;
            updated.task = "Unload";
            const hasAm = manualSchedule.some(day => day.groupId === updated.groupId && day.dayPart === "AM");
            if (!hasAm){
                manualSchedule.push({
                    id: createId(),
                    groupId: updated.groupId,
                    dayPart: "AM",
                    task: "Load",
                    men: updated.men,
                    hours: 4
                });
            }
        }
        if (value === "Full Day"){
            manualSchedule = manualSchedule.filter(day => day.groupId !== row.groupId || day.id === row.id);
            manualSchedule = manualSchedule.map(day => day.id === row.id ? { ...day, dayPart: "Full Day", hours: 8, task: day.task === "Unload" ? "Load and Deliver" : day.task } : day);
        }
        normalizeGroup(row.groupId);
    }

    renderAll();
}

function renderSchedulePlanner(){
    const list = document.getElementById("scheduleList");
    if (!list) return;

    const groups = [];
    const seen = new Set();
    manualSchedule.forEach(day => {
        if (!seen.has(day.groupId)){
            seen.add(day.groupId);
            groups.push(day.groupId);
        }
    });

    list.innerHTML = groups.map((groupId, groupIndex) => {
        const rows = manualSchedule.filter(day => day.groupId === groupId).sort((a,b) => {
            const order = { "Full Day": 0, "AM": 1, "PM": 2 };
            return order[a.dayPart] - order[b.dayPart];
        });

        return rows.map((day, rowIndex) => `
            <div class="schedule-row">
                <div class="schedule-row-head">
                    <div class="schedule-row-title">Day ${groupIndex + 1}${rows.length > 1 ? ` · ${day.dayPart}` : ""}</div>
                    ${rowIndex === 0 && manualSchedule.length > 1 ? `<button class="schedule-remove" onclick="removeScheduleDay('${day.id}')">Delete</button>` : ""}
                </div>
                <div class="schedule-grid">
                    <div>
                        <label class="mini-label">Task</label>
                        <select class="field" onchange="updateScheduleDay('${day.id}','task',this.value)">
                            ${optionHtml(TASK_OPTIONS, day.task)}
                        </select>
                    </div>
                    <div>
                        <label class="mini-label">Day Part</label>
                        <select class="field" onchange="updateScheduleDay('${day.id}','dayPart',this.value)">
                            ${optionHtml(DAY_PARTS, day.dayPart)}
                        </select>
                    </div>
                    <div>
                        <label class="mini-label">Men</label>
                        <select class="field" onchange="updateScheduleDay('${day.id}','men',this.value)">
                            ${optionHtml([1,2,3,4], day.men)}
                        </select>
                    </div>
                    <div>
                        <label class="mini-label">Hours</label>
                        <input type="number" min="0" step="0.5" class="field" value="${day.hours}" oninput="updateScheduleDay('${day.id}','hours',this.value)" />
                    </div>
                </div>
            </div>
        `).join("");
    }).join("");
}

function calcScheduleValidation(packing, loading, unloading, special, state){
    const effectiveLoadHours = round2(loading.hours);
    const required = {
        Pack: packing.packHours,
        Load: effectiveLoadHours,
        Unload: unloading.hours
    };

    const allocated = {
        Pack: 0,
        Load: 0,
        Unload: 0
    };

    let sharedPackLoadPool = 0;
    let sharedLoadUnloadPool = 0;

    const groups = {};
    manualSchedule.forEach(day => {
        if (!groups[day.groupId]) groups[day.groupId] = [];
        groups[day.groupId].push(day);
    });

    Object.values(groups).forEach(rows => {
        const hasAmLoadish = rows.some(day => day.dayPart === "AM" && ["Load", "Pack and Load", "Load and Deliver", "Load and Travel"].includes(day.task));

        rows.forEach(day => {
            const men = Number(day.men) || 0;
            const hours = Number(day.hours) || 0;
            const capacity = men * hours;

            switch(day.task){
                case "Pack":
                    allocated.Pack += capacity;
                    break;
                case "Unload":
                case "Deliver and Crew Return":
                    allocated.Unload += capacity;
                    break;
                case "Pack and Load":
                    if (day.dayPart === "AM") {
                        sharedPackLoadPool += capacity;
                    } else if (day.dayPart === "PM" && hasAmLoadish) {
                        const pmLoadHours = round2((men * hours * AFTERNOON_LOAD_RATE_AFTER_AM) / state.loadRate);
                        sharedPackLoadPool += pmLoadHours;
                    } else {
                        sharedPackLoadPool += capacity;
                    }
                    break;
                case "Load and Deliver":
                    if (day.dayPart === "AM") {
                        sharedLoadUnloadPool += capacity;
                    } else if (day.dayPart === "PM" && hasAmLoadish) {
                        const pmLoadHours = round2((men * hours * AFTERNOON_LOAD_RATE_AFTER_AM) / state.loadRate);
                        sharedLoadUnloadPool += pmLoadHours + Math.max(0, capacity - pmLoadHours);
                    } else {
                        sharedLoadUnloadPool += capacity;
                    }
                    break;
                case "Load":
                case "Load and Travel": {
                    let loadHoursEquivalent = capacity;
                    if (day.dayPart === "PM" && hasAmLoadish) {
                        const pmVolume = men * hours * AFTERNOON_LOAD_RATE_AFTER_AM;
                        loadHoursEquivalent = round2(pmVolume / state.loadRate);
                    }
                    allocated.Load += loadHoursEquivalent;
                    break;
                }
                default:
                    break;
            }
        });
    });

    const packNeedAfterDirect = Math.max(0, required.Pack - allocated.Pack);
    const packLoadPoolToPack = Math.min(sharedPackLoadPool, packNeedAfterDirect);
    allocated.Pack += packLoadPoolToPack;
    allocated.Load += Math.max(0, sharedPackLoadPool - packLoadPoolToPack);

    const loadNeedAfterPackPool = Math.max(0, required.Load - allocated.Load);
    const loadUnloadPoolToLoad = Math.min(sharedLoadUnloadPool, loadNeedAfterPackPool);
    allocated.Load += loadUnloadPoolToLoad;
    allocated.Unload += Math.max(0, sharedLoadUnloadPool - loadUnloadPoolToLoad);

    const passIcon = "✓";
    const failIcon = "✕";
    const warnIcon = "!";

    const results = Object.keys(required).map(task => {
        const req = required[task] || 0;
        const cap = allocated[task] || 0;
        const diff = round2(cap - req);

        if (req === 0 && cap === 0) {
            return { type: "ok", text: `${passIcon} ${task} not required and none allocated.` };
        }
        if (cap + 0.01 < req) {
            return { type: "error", text: `${failIcon} ${task} short by ${Math.abs(diff).toFixed(2)} man-hours.` };
        }
        if (diff > 0.5) {
            return { type: "warn", text: `${warnIcon} ${task} has ${diff.toFixed(2)} spare man-hours allocated.` };
        }
        return { type: "ok", text: `${passIcon} ${task} capacity matches requirement.` };
    });

    if (sharedPackLoadPool > 0){
        results.push({ type: "ok", text: `${passIcon} Pack and Load rows use a shared labour pool, so spare pack capacity can offset load demand.` });
    }
    if (sharedLoadUnloadPool > 0){
        results.push({ type: "ok", text: `${passIcon} Load and Deliver rows use a shared labour pool, so spare load capacity can offset unload demand.` });
    }
    results.push({
        type: special.extraTransitHours > 0 ? "warn" : "ok",
        text: special.extraTransitHours > 0
            ? `${warnIcon} Transit beyond the first 30 minutes adds ${special.extraTransitHours.toFixed(2)} hours to the unload side and may reduce delivery-side feasibility.`
            : `${passIcon} Transit is within the first 30 minutes included allowance.`
    });
    results.push({
        type: "ok",
        text: `${passIcon} Planner load validation uses ${MORNING_LOAD_RATE} cuft per man-hour in the morning and ${AFTERNOON_LOAD_RATE_AFTER_AM} cuft per man-hour for PM loading when it follows AM loading on the same day.`
    });
    results.push({
        type: "ok",
        text: `${passIcon} Load-side specials are included in loading, and unload-side specials are included in unloading for schedule checking.`
    });

    return results;
}

function renderValidation(packing, loading, unloading, special, state){
    const el = document.getElementById("validationList");
    if (!el) return;
    const items = calcScheduleValidation(packing, loading, unloading, special, state);
    el.innerHTML = items.map(item => `<div class="validation-item validation-${item.type}">${item.text}</div>`).join("");
}

function renderAll(){
    const photonFeed = getPhotonFeed();
    const state = getState();
    const sequenceLabelDisplay = document.getElementById("sequenceLabelDisplay");
if (sequenceLabelDisplay) sequenceLabelDisplay.textContent = photonFeed.sequenceLabel || "—";
    const packing = calcPacking(state);
    const boxVolume = round2(calcBoxVolume(state));
    const totalVolume = round2(state.furnitureVol + boxVolume);
    const furnitureDisplay = document.getElementById("furnitureVolDisplay");
if (furnitureDisplay) furnitureDisplay.textContent = state.furnitureVol;

const apDisplay = document.getElementById("qty_ap_display");
if (apDisplay) apDisplay.textContent = state.qty.ap;

const cgDisplay = document.getElementById("qty_cg_display");
if (cgDisplay) cgDisplay.textContent = state.qty.cg;

const booksDisplay = document.getElementById("qty_books_display");
if (booksDisplay) booksDisplay.textContent = state.qty.books;

const linenDisplay = document.getElementById("qty_linen_display");
if (linenDisplay) linenDisplay.textContent = state.qty.linen;

const wrDisplay = document.getElementById("qty_wr_display");
if (wrDisplay) wrDisplay.textContent = state.qty.wr;
    const special = calcSpecialLabour(state);
    const loading = calcLoading(totalVolume, state.loadRate, special.loadSideHours);
    const unloading = calcUnloading(totalVolume, state.unloadRate, special.unloadSideHours);

    document.getElementById("summaryMode").textContent = getPackModeLabel(state.packOption);
    document.getElementById("summaryTotalVolume").textContent = totalVolume;
    document.getElementById("summaryPackHours").textContent = packing.packHours.toFixed(2);
    document.getElementById("summaryPackDays").textContent = packing.packDays.toFixed(1);
    document.getElementById("summarySpecialHours").textContent = special.specialHours.toFixed(2);
    document.getElementById("summaryLoadHours").textContent = loading.hours.toFixed(2);
    document.getElementById("summaryLoadDays").textContent = loading.days.toFixed(1);
    document.getElementById("summaryLoadCompletion").textContent = loading.completionCrew.toFixed(1);
    document.getElementById("summaryLoadRate").textContent = state.loadRate;

    document.getElementById("summaryUnloadHours").textContent = unloading.hours.toFixed(2);
    document.getElementById("summaryUnloadDays").textContent = unloading.days.toFixed(1);
    document.getElementById("summaryUnloadCompletion").textContent = unloading.completionCrew.toFixed(1);
    document.getElementById("summaryUnloadRate").textContent = state.unloadRate;

    const packingRule = state.packOption === "none"
        ? "No packing selected, so packing labour is held at zero."
        : state.packOption === "cg"
            ? "CG packing selected, so only CG cartons contribute to packing labour."
            : "Full packing selected, so all carton types contribute to packing labour.";

    document.getElementById("logicText").textContent =
        `${packingRule} Total volume is furniture volume plus calculated box volume. ` +
        `Loft effects volume is used for extra loft labour only and does not change total move volume. ` +
        `Loading uses total volume ÷ ${state.loadRate} cuft per man-hour, then adds load-side specials. ` +
        `Unloading uses total volume ÷ ${state.unloadRate} cuft per man-hour, then adds unload-side specials. ` +
        `Two regular frame beds and 50 cuft of export wrap are treated as already included before extra special time is added.`;

    document.getElementById("specialText").textContent =
        `Frame beds: ${special.breakdown.frame.toFixed(2)} hrs extra after first ${special.breakdown.includedFrameBeds} included · ` +
        `Bunk beds: ${special.breakdown.bunk.toFixed(2)} hrs · ` +
        `${state.special.customNote ? state.special.customNote : "Custom item"}: ${special.breakdown.custom.toFixed(2)} hrs · ` +
        `Upright pianos: ${special.breakdown.upright.toFixed(2)} hrs · ` +
        `Baby / grand pianos: ${special.breakdown.grand.toFixed(2)} hrs · ` +
        `Grandfather clocks: ${special.breakdown.clock.toFixed(2)} hrs · ` +
        `Appliances: ${special.breakdown.appliance.toFixed(2)} hrs · ` +
        `Crating: ${special.breakdown.crate.toFixed(2)} hrs · ` +
        `Loft effects: ${special.breakdown.loft.toFixed(2)} hrs · ` +
        `Export wrapping: ${special.breakdown.exportWrap.toFixed(2)} hrs extra after first ${special.breakdown.includedExportWrapVol} cuft included · ` +
        `Transit impact: ${special.breakdown.transit.toFixed(2)} hrs after first 30 mins included. ` +
        `Load side specials: ${special.loadSideHours.toFixed(2)} hrs · Unload side specials: ${special.unloadSideHours.toFixed(2)} hrs.`;

    renderSchedulePlanner();
    renderValidation(packing, loading, unloading, special, state);
}

renderAll();
</script>
