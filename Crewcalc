<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Photon Summary & Pricing Lab</title>
<style>
:root{
    --bg:#f1f5f9;
    --card:#ffffff;
    --navy:#0f172a;
    --navy-2:#1e293b;
    --blue:#3b82f6;
    --blue-2:#2563eb;
    --blue-50:#eff6ff;
    --red:#dc2626;
    --red-50:#fef2f2;
    --slate-50:#f8fafc;
    --slate-100:#f1f5f9;
    --slate-200:#e2e8f0;
    --slate-300:#cbd5e1;
    --slate-400:#94a3b8;
    --slate-500:#64748b;
    --slate-700:#334155;
    --shadow:0 10px 30px rgba(15,23,42,0.08);
}
*{box-sizing:border-box;}
body{
    margin:0;
    padding:18px;
    background:var(--bg);
    font-family:Inter,Segoe UI,Arial,sans-serif;
    color:var(--navy);
}
button,input,select,textarea{font:inherit;}
.shell{max-width:1380px;margin:0 auto;}
.topbar{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:16px;}
.brand{display:flex;align-items:center;gap:12px;}
.logo-circle{width:34px;height:34px;border-radius:999px;background:var(--navy);border:2px solid #ef4444;display:flex;align-items:center;justify-content:center;}
.logo-inner{width:10px;height:10px;border-radius:999px;background:#ef4444;box-shadow:0 0 10px rgba(239,68,68,0.6);}
.brand-title{font-size:28px;font-weight:900;line-height:1;text-transform:uppercase;letter-spacing:-0.05em;margin:0;}
.brand-sub{font-size:10px;font-weight:900;color:var(--blue);text-transform:uppercase;letter-spacing:.22em;margin-top:4px;}
.status-pill{border:1px solid var(--slate-300);background:var(--card);border-radius:999px;padding:8px 12px;font-size:10px;font-weight:900;text-transform:uppercase;color:var(--slate-500);white-space:nowrap;}
.layout{display:grid;grid-template-columns:360px 1fr;gap:16px;align-items:start;}
.stack{display:grid;gap:16px;}
.panel{background:var(--card);border:1px solid var(--slate-200);border-radius:20px;box-shadow:var(--shadow);overflow:hidden;}
.panel-head{background:var(--navy);padding:14px 16px;border-bottom:1px solid var(--navy-2);}
.panel-title{color:#fff;font-size:12px;font-weight:900;text-transform:uppercase;}
.panel-subtitle{color:#93c5fd;font-size:10px;font-weight:800;text-transform:uppercase;margin-top:4px;}
.panel-body{padding:16px;}
.section-block{border:1px solid var(--slate-200);border-radius:16px;padding:14px;background:var(--slate-50);}
.section-block + .section-block{margin-top:14px;}
.section-title{font-size:11px;font-weight:900;text-transform:uppercase;color:var(--navy);margin-bottom:12px;}
.mini-label{display:block;font-size:10px;font-weight:900;color:var(--slate-500);text-transform:uppercase;margin-bottom:6px;letter-spacing:.02em;}
.field{width:100%;border:1.5px solid var(--slate-300);border-radius:10px;padding:11px 12px;font-size:14px;font-weight:700;outline:none;background:#fff;color:var(--navy);}
.field:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(59,130,246,0.08);}
.field.readonly{background:var(--slate-50);color:var(--slate-700);}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.summary-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;}
.summary-card{background:#fff;border:1px solid var(--slate-200);border-radius:16px;padding:16px;min-height:118px;}
.summary-label{font-size:10px;font-weight:900;text-transform:uppercase;color:var(--slate-400);margin-bottom:8px;line-height:1.35;}
.summary-value{font-size:28px;font-weight:900;line-height:1;color:var(--navy);}
.summary-sub{font-size:10px;font-weight:800;text-transform:uppercase;color:var(--slate-500);margin-top:8px;line-height:1.35;}
.document-block{background:#fff;border:1px solid var(--slate-200);border-radius:14px;padding:14px;}
.document-section + .document-section{margin-top:14px;padding-top:12px;border-top:1px solid var(--slate-200);}
.document-heading{font-size:10px;font-weight:900;text-transform:uppercase;color:var(--slate-400);margin-bottom:8px;letter-spacing:.04em;}
.document-lines{display:grid;gap:6px;}
.document-line{font-size:12px;font-weight:700;color:var(--slate-700);line-height:1.45;}
.document-empty{font-size:12px;font-weight:700;color:var(--slate-500);line-height:1.45;font-style:italic;}
.note-card{background:var(--blue-50);border:1px solid #bfdbfe;color:#1d4ed8;border-radius:14px;padding:12px 14px;font-size:11px;font-weight:800;text-transform:uppercase;line-height:1.45;}
.schedule-grid,.pricing-grid{display:grid;gap:12px;}
.schedule-row{
    display:grid;
    grid-template-columns:minmax(90px,.9fr) minmax(130px,1fr) minmax(180px,1.4fr) 92px 92px 92px 92px 84px;
    gap:10px;
    align-items:end;
    border:1px solid var(--slate-200);
    border-radius:16px;
    padding:12px;
    background:#fff;
}
.pricing-row{
    display:grid;
    grid-template-columns:1.35fr 1.8fr .7fr .85fr .85fr;
    gap:10px;
    align-items:end;
    border:1px solid var(--slate-200);
    border-radius:16px;
    padding:12px;
    background:#fff;
}
.action-btn{height:44px;border-radius:10px;border:1px solid transparent;padding:0 14px;font-size:11px;font-weight:900;text-transform:uppercase;cursor:pointer;}
.action-btn.blue{background:var(--blue);color:#fff;border-color:var(--blue-2);}
.action-btn.white{background:#fff;color:var(--slate-700);border-color:var(--slate-300);}
.action-btn.red{background:var(--red-50);color:var(--red);border-color:#fecaca;}
.toolbar{margin-top:12px;display:flex;gap:10px;flex-wrap:wrap;}
.footer-note{margin-top:12px;font-size:10px;font-weight:800;text-transform:uppercase;color:var(--slate-400);line-height:1.45;}
textarea.field{min-height:92px;resize:vertical;line-height:1.45;}
@media (max-width:1100px){
    .layout{grid-template-columns:1fr;}
    .summary-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
}
@media (max-width:980px){
    .pricing-row,.schedule-row{grid-template-columns:1fr 1fr;}
}
@media (max-width:760px){
    .summary-grid,.grid-2{grid-template-columns:1fr;}
    .topbar{align-items:flex-start;flex-direction:column;}
}
</style>
</head>
<body>
<div class="shell">
    <div class="topbar">
        <div class="brand">
            <div class="logo-circle"><div class="logo-inner"></div></div>
            <div>
                <div class="brand-title">Photon</div>
                <div class="brand-sub">Summary & Pricing Lab</div>
            </div>
        </div>
        <div class="status-pill">Standalone Prototype · Safe Summary Layer</div>
    </div>

    <div class="layout">
        <div class="panel">
            <div class="panel-head">
                <div class="panel-title">Prototype Controls</div>
                <div class="panel-subtitle">Use this as the safe side project before wiring into the live app</div>
            </div>
            <div class="panel-body">
                <div class="section-block">
                    <div class="section-title">Sequence Selection</div>
                    <div>
                        <label class="mini-label">Selected Sequence</label>
                        <select id="sequenceSelect" class="field"></select>
                    </div>
                </div>

                <div class="section-block">
                    <div class="section-title">Removal Crew Responsibilities</div>
                    <div id="leftResponsibilityCard"></div>
                </div>

                <div class="section-block">
                    <div class="section-title">Exclusions / Customer Responsibilities</div>
                    <div id="leftExcludedCard"></div>
                    <div style="height:12px"></div>
                    <div>
                        <label class="mini-label">Add Manual Excluded Item</label>
                        <div class="grid-2">
                            <input id="manualExcludedInput" class="field" placeholder="e.g. Garage racking" />
                            <button type="button" class="field" style="cursor:pointer;background:var(--blue);color:#fff;border-color:var(--blue-2);" id="manualExcludedAddBtn">Add</button>
                        </div>
                    </div>
                    <div style="height:12px"></div>
                    <div>
                        <label class="mini-label">Manual Excluded Notes</label>
                        <textarea id="manualExcludedNotes" class="field" placeholder="Short pricing / summary notes for excluded scope"></textarea>
                    </div>
                </div>

                <div class="note-card">
                    This prototype is designed to aggregate summary data first. Pricing is visible in-page, but still isolated from the live app.
                </div>
            </div>
        </div>

        <div class="stack">
            <div class="panel">
                <div class="panel-head">
                    <div class="panel-title">Schedule Planner</div>
                    <div class="panel-subtitle">Manual AM / PM planning block that can later be lifted from the calculator</div>
                </div>
                <div class="panel-body">
                    <div class="note-card">
                        This is a quick planner version. Use it to add day rows manually, then let the vans / foreman / crew totals feed directly into pricing below.
                    </div>
                    <div id="schedulePlanner"></div>
                    <div class="toolbar">
                        <button type="button" class="action-btn white" id="addScheduleRowBtn">Add Schedule Row</button>
                    </div>
                </div>
            </div>

            <div class="panel">
                <div class="panel-head">
                    <div class="panel-title">Pricing Placeholder</div>
                    <div class="panel-subtitle">Customer-facing numbers first, cost lines beneath</div>
                </div>
                <div class="panel-body">
                    <div class="summary-grid">
                        <div class="summary-card">
                            <div class="summary-label">Total Costs</div>
                            <div class="summary-value" id="totalCosts">0.00</div>
                            <div class="summary-sub">Auto-added from pricing lines</div>
                        </div>
                        <div class="summary-card">
                            <div class="summary-label">Price To Customer</div>
                            <div class="summary-value" id="customerPriceDisplay">0.00</div>
                            <div class="summary-sub">Manual sell price input</div>
                        </div>
                        <div class="summary-card">
                            <div class="summary-label">Gross Margin</div>
                            <div class="summary-value" id="grossMarginDisplay">0.00</div>
                            <div class="summary-sub" id="grossMarginSub">Customer price minus total costs</div>
                        </div>
                        <div class="summary-card">
                            <div>
                                <label class="mini-label">Price To Customer</label>
                                <input id="customerPriceInput" type="number" min="0" step="0.01" class="field" value="0" onchange="renderPricing(getSelectedSequence())" />
                            </div>
                            <div style="height:12px"></div>
                            <button type="button" class="action-btn blue" id="savePricingBtn" style="width:100%;">Save Pricing</button>
                        </div>
                    </div>

                    <div style="height:16px"></div>

                    <div class="note-card">
                        Quantity can be fed from inventory later. Unit costs auto-populate but stay editable. One save button sits at the top next to customer pricing.
                    </div>

                    <div class="pricing-grid" id="pricingGrid"></div>

                    <div class="toolbar"></div>

                    <div class="footer-note">Crew replaces porters in this version. Standard default rates are preloaded and can be edited.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
const prototypeState = {
    selectedSequenceId: "seq_1",
    manualExcluded: [],
    manualExcludedNotes: "",
    sequences: [
        {
            id: "seq_1",
            label: "Sequence 1",
            moveType: "DOMESTIC LOCAL",
            packingType: "FULL PACKING",
            inventory: [
                { name: "3 Seater Sofa", volume: 180, cartons: null, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Frame Bed", volume: 55, cartons: null, actionFlags: { dismantle:true, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Dining Table", volume: 75, cartons: null, actionFlags: { dismantle:true, exportWrap:true, crate:false, disconnect:false, handyman:false, damage:false, noted:true, excluded:false } },
                { name: "Grandfather Clock", volume: 25, cartons: null, actionFlags: { dismantle:false, exportWrap:false, crate:true, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Dishwasher", volume: 20, cartons: null, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:true, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Wall Shelving", volume: 10, cartons: null, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:true, damage:false, noted:false, excluded:true } },
                { name: "China & Glass Cartons", volume: 0, cartons: { type: "CG", qty: 16 }, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "All Purpose Cartons", volume: 0, cartons: { type: "AP", qty: 24 }, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Book Cartons", volume: 0, cartons: { type: "BOOKS", qty: 8 }, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } }
            ],
            calculator: {
                cartonTotals: { AP: 24, CG: 16, BOOKS: 8, LINEN: 0, WR: 0 },
                exportWrapQty: 75
            }
        },
        {
            id: "seq_2",
            label: "Sequence 2",
            moveType: "EXPORT",
            packingType: "EXPORT WRAP",
            inventory: [
                { name: "King Mattress", volume: 60, cartons: null, actionFlags: { dismantle:false, exportWrap:true, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Bunk Bed", volume: 85, cartons: null, actionFlags: { dismantle:true, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Baby Grand Piano", volume: 110, cartons: null, actionFlags: { dismantle:false, exportWrap:false, crate:true, disconnect:false, handyman:false, damage:true, noted:true, excluded:false } },
                { name: "Utility Shelf", volume: 18, cartons: null, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:true } },
                { name: "Wardrobe Cartons", volume: 0, cartons: { type: "WR", qty: 6 }, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } },
                { name: "Linen Cartons", volume: 0, cartons: { type: "LINEN", qty: 12 }, actionFlags: { dismantle:false, exportWrap:false, crate:false, disconnect:false, handyman:false, damage:false, noted:false, excluded:false } }
            ],
            calculator: {
                cartonTotals: { AP: 0, CG: 0, BOOKS: 0, LINEN: 12, WR: 6 },
                exportWrapQty: 120
            }
        }
    ]
};

const CARTON_TYPES = ["AP", "CG", "BOOKS", "LINEN", "WR"];
const PRICING_DEFAULTS = [
    { label: "Vans", qty: 1, unitCost: 120 },
    { label: "Drivers / Foreman", qty: 1, unitCost: 200 },
    { label: "Crew", qty: 0, unitCost: 200 },
    { label: "Mileage", qty: 0, unitCost: 0.45 },
    { label: "Consumables", qty: 0, unitCost: 0 },
    { label: "Cartons", qty: 48, unitCost: 2.5 },
    { label: "Export Wrap", qty: 0, unitCost: 0.30 },
    { label: "Nights Out", qty: 0, unitCost: 40 },
    { label: "Crating", qty: 0, unitCost: 0 },
    { label: "Handyman Rate", qty: 0, unitCost: 0 },
    { label: "Parking / Parking Admin Fees", qty: 0, unitCost: 0 },
    { label: "Hoist / Crane", qty: 0, unitCost: 0 },
    { label: "Ferry", qty: 0, unitCost: 0 }
];
const MANDATORY_LABELS = ["Vans", "Drivers / Foreman", "Crew", "Mileage", "Consumables", "Cartons", "Export Wrap", "Nights Out"];
const OPTIONAL_CHOICES = ["Custom", "Handyman Rate", "Parking / Parking Admin Fees", "Hoist / Crane", "Ferry", "Crating"];
const TASK_OPTIONS = ["Custom", "Pack", "Load", "Unload", "Pack and Load", "Load and Deliver", "Load and Travel", "Deliver and Crew Return"];
const DAY_PARTS = ["AM", "PM", "Full Day"];

let pricingSaved = false;
let pricingBySequence = {};
let scheduleBySequence = {};

function money(value){ return Number(value || 0).toFixed(2); }
function createId(){ return `row_${Date.now()}_${Math.random().toString(36).slice(2,7)}`; }
function escapeHtml(value){ return String(value == null ? "" : value).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;"); }
function escapeAttr(value){ return String(value == null ? "" : value).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;"); }

function getSelectedSequence(){
    return prototypeState.sequences.find(seq => seq.id === prototypeState.selectedSequenceId) || prototypeState.sequences[0];
}

function summariseInventory(sequence){
    const lines = sequence.inventory || [];
    const actions = { dismantle: [], exportWrap: [], crate: [], disconnect: [], handyman: [], damage: [], noted: [], excluded: [] };
    lines.forEach(line => {
        const flags = line.actionFlags || {};
        if (flags.dismantle) actions.dismantle.push(line.name);
        if (flags.exportWrap) actions.exportWrap.push(line.name);
        if (flags.crate) actions.crate.push(line.name);
        if (flags.disconnect) actions.disconnect.push(line.name);
        if (flags.handyman) actions.handyman.push(line.name);
        if (flags.damage) actions.damage.push(line.name);
        if (flags.noted) actions.noted.push(line.name);
        if (flags.excluded) actions.excluded.push(line.name);
    });
    return { actions };
}

function buildDocumentLines(arr, emptyText){
    if (!arr.length) return `<div class="document-empty">${escapeHtml(emptyText)}</div>`;
    return `<div class="document-lines">${arr.map(item => `<div class="document-line">• ${escapeHtml(item)}</div>`).join("")}</div>`;
}

function getScheduleRows(sequence){
    if (!scheduleBySequence[sequence.id]){
        scheduleBySequence[sequence.id] = [
            { id: createId(), dayLabel: "Day 1", task: "Pack and Load", customTask: "", dayPart: "AM", vans: 1, foreman: 1, crew: 2 },
            { id: createId(), dayLabel: "Day 1", task: "Load and Deliver", customTask: "", dayPart: "PM", vans: 1, foreman: 1, crew: 2 }
        ];
    }
    return scheduleBySequence[sequence.id];
}

function calcScheduleTotals(sequence){
    return getScheduleRows(sequence).reduce((acc, row) => {
        acc.vans += Number(row.vans || 0);
        acc.foreman += Number(row.foreman || 0);
        acc.crew += Number(row.crew || 0);
        return acc;
    }, { vans: 0, foreman: 0, crew: 0 });
}

function syncPricingFromSchedule(sequence){
    const totals = calcScheduleTotals(sequence);
    if (!pricingBySequence[sequence.id]) return;
    pricingBySequence[sequence.id] = pricingBySequence[sequence.id].map(line => {
        if (line.label === "Vans") return { ...line, qty: totals.vans };
        if (line.label === "Drivers / Foreman") return { ...line, qty: totals.foreman };
        if (line.label === "Crew") return { ...line, qty: totals.crew };
        return line;
    });
}
function ensureSingleBlankExtra(sequence){
    if (!pricingBySequence[sequence.id]) return;

    const mandatoryLabels = ["Vans", "Drivers / Foreman", "Crew", "Mileage", "Consumables", "Cartons", "Export Wrap", "Nights Out"];

    const lines = pricingBySequence[sequence.id];
    const mandatory = lines.filter(line => mandatoryLabels.includes(line.label));
    const extras = lines.filter(line => !mandatoryLabels.includes(line.label));
    const usedExtras = extras.filter(line => line.label && line.label !== "");

    pricingBySequence[sequence.id] = [...mandatory, ...usedExtras];

    if (usedExtras.length < 10){
        pricingBySequence[sequence.id].push({
            id: createId(),
            label: "",
            customLabel: "",
            qty: 0,
            unitCost: 0
        });
    }
}

function getPricingLines(sequence){
    if (!pricingBySequence[sequence.id]){
        const calc = sequence.calculator || {};
        pricingBySequence[sequence.id] = PRICING_DEFAULTS.map(item => {
            let qty = item.qty;
            if (item.label === "Cartons") qty = Object.values(calc.cartonTotals || {}).reduce((sum, val) => sum + Number(val || 0), 0);
            if (item.label === "Export Wrap") qty = Number(calc.exportWrapQty || 0);
            return {
                id: createId(),
                label: item.label,
                customLabel: "",
                qty,
                unitCost: item.unitCost
            };
        });
    }

    syncPricingFromSchedule(sequence);
    ensureSingleBlankExtra(sequence);
    return pricingBySequence[sequence.id];
}

function getPricingLines(sequence){
    if (!pricingBySequence[sequence.id]){
        const calc = sequence.calculator || {};
        pricingBySequence[sequence.id] = PRICING_DEFAULTS.map(item => {
            let qty = item.qty;
            if (item.label === "Cartons") qty = Object.values(calc.cartonTotals || {}).reduce((sum, val) => sum + Number(val || 0), 0);
            if (item.label === "Export Wrap") qty = Number(calc.exportWrapQty || 0);
            return { id: createId(), label: item.label, customLabel: "", qty, unitCost: item.unitCost };
        });
    }
    syncPricingFromSchedule(sequence);
    ensureSingleBlankExtra(sequence);
    return pricingBySequence[sequence.id];
}

function lineTotal(line){
    return Number(line.qty || 0) * Number(line.unitCost || 0);
}

function calcTotalCosts(sequence){
    return getPricingLines(sequence).reduce((sum, line) => sum + lineTotal(line), 0);
}

function renderSequenceSelect(){
    const select = document.getElementById("sequenceSelect");
    select.innerHTML = prototypeState.sequences.map(seq => `<option value="${seq.id}" ${seq.id === prototypeState.selectedSequenceId ? "selected" : ""}>${escapeHtml(seq.label)}</option>`).join("");
}

function renderResponsibilitySummary(inventorySummary){
    const actions = inventorySummary.actions;
    document.getElementById("leftResponsibilityCard").innerHTML = `
        <div class="document-block">
            <div class="document-section">
                <div class="document-heading">Dismantle Items</div>
                ${buildDocumentLines(actions.dismantle, "None")}
            </div>
            <div class="document-section">
                <div class="document-heading">Export Wrap Items</div>
                ${buildDocumentLines(actions.exportWrap, "None")}
            </div>
            <div class="document-section">
                <div class="document-heading">Crated Items</div>
                ${buildDocumentLines(actions.crate, "None")}
            </div>
            <div class="document-section">
                <div class="document-heading">Disconnect Items</div>
                ${buildDocumentLines(actions.disconnect, "None")}
            </div>
            <div class="document-section">
                <div class="document-heading">Handyman Items</div>
                ${buildDocumentLines(actions.handyman, "None")}
            </div>
            <div class="document-section">
                <div class="document-heading">Damage Items</div>
                ${buildDocumentLines(actions.damage, "None")}
            </div>
            <div class="document-section">
                <div class="document-heading">Noted Items</div>
                ${buildDocumentLines(actions.noted, "None")}
            </div>
        </div>
    `;
}

function renderExcludedSummary(inventorySummary){
    const listedExcluded = inventorySummary.actions.excluded || [];
    const manualExcluded = prototypeState.manualExcluded || [];
    document.getElementById("leftExcludedCard").innerHTML = `
        <div class="document-block">
            <div class="document-section">
                <div class="document-heading">Inventory Excluded Items</div>
                ${buildDocumentLines(listedExcluded, "None")}
            </div>
            <div class="document-section">
                <div class="document-heading">Manual Excluded Items</div>
                ${buildDocumentLines(manualExcluded, "None yet")}
            </div>
        </div>
    `;
}

function addManualExcluded(){
    const input = document.getElementById("manualExcludedInput");
    const value = input.value.trim();
    if (!value) return;
    prototypeState.manualExcluded.push(value);
    input.value = "";
    renderAll();
}

function updateManualExcludedNotes(value){
    prototypeState.manualExcludedNotes = value;
}

function addScheduleRow(){
    const sequence = getSelectedSequence();
    const rows = getScheduleRows(sequence);
    rows.push({ id: createId(), dayLabel: `Day ${rows.length + 1}`, task: "Load", customTask: "", dayPart: "AM", vans: 1, foreman: 1, crew: 2 });
    pricingSaved = false;
    syncPricingFromSchedule(sequence);
    renderAll();
}

function updateScheduleRow(id, field, value){
    const sequence = getSelectedSequence();
    scheduleBySequence[sequence.id] = getScheduleRows(sequence).map(row => {
        if (row.id !== id) return row;
        if (["vans","foreman","crew"].includes(field)) return { ...row, [field]: Number(value || 0) };
        return { ...row, [field]: value };
    });
    pricingSaved = false;
    syncPricingFromSchedule(sequence);
    renderAll();
}

function deleteScheduleRow(id){
    const sequence = getSelectedSequence();
    let rows = getScheduleRows(sequence).filter(row => row.id !== id);
    if (!rows.length){
        rows = [{ id: createId(), dayLabel: "Day 1", task: "Load", customTask: "", dayPart: "AM", vans: 1, foreman: 1, crew: 2 }];
    }
    scheduleBySequence[sequence.id] = rows;
    pricingSaved = false;
    syncPricingFromSchedule(sequence);
    renderAll();
}

function renderSchedulePlanner(sequence){
    const rows = getScheduleRows(sequence);
    document.getElementById("schedulePlanner").innerHTML = `
        <div class="schedule-grid">
            ${rows.map(row => `
                <div class="schedule-row">
                    <div>
                        <label class="mini-label">Day</label>
                        <input class="field" value="${escapeAttr(row.dayLabel)}" onchange="updateScheduleRow('${row.id}','dayLabel',this.value)" />
                    </div>
                    <div>
                        <label class="mini-label">Task</label>
                        <select class="field" onchange="updateScheduleRow('${row.id}','task',this.value)">
                            ${TASK_OPTIONS.map(opt => `<option value="${opt}" ${opt === row.task ? "selected" : ""}>${opt}</option>`).join("")}
                        </select>
                    </div>
                    <div>
                        <label class="mini-label">Custom Task</label>
                        <input class="field" value="${escapeAttr(row.customTask || "")}" ${row.task === "Custom" ? "" : "readonly"} onchange="updateScheduleRow('${row.id}','customTask',this.value)" placeholder="Use only if task is custom" />
                    </div>
                    <div>
                        <label class="mini-label">AM / PM</label>
                        <select class="field" onchange="updateScheduleRow('${row.id}','dayPart',this.value)">
                            ${DAY_PARTS.map(opt => `<option value="${opt}" ${opt === row.dayPart ? "selected" : ""}>${opt}</option>`).join("")}
                        </select>
                    </div>
                    <div>
                        <label class="mini-label">Vans</label>
                        <input type="number" min="0" class="field" value="${row.vans}" oninput="updateScheduleRow('${row.id}','vans',this.value)" />
                    </div>
                    <div>
                        <label class="mini-label">Driver / Foreman</label>
                        <input type="number" min="0" class="field" value="${row.foreman}" oninput="updateScheduleRow('${row.id}','foreman',this.value)" />
                    </div>
                    <div>
                        <label class="mini-label">Crew</label>
                        <input type="number" min="0" class="field" value="${row.crew}" oninput="updateScheduleRow('${row.id}','crew',this.value)" />
                    </div>
                    <div>
                        <button type="button" class="action-btn red" onclick="deleteScheduleRow('${row.id}')">Delete</button>
                    </div>
                </div>
            `).join("")}
        </div>
    `;
}

function addPricingLine(){
    const sequence = getSelectedSequence();
    const lines = getPricingLines(sequence);
    const usedExtras = lines.filter(line => !MANDATORY_LABELS.includes(line.label) && line.label && line.label !== "");
    if (usedExtras.length >= 10) return;
    pricingBySequence[sequence.id].push({ id: createId(), label: "", customLabel: "", qty: 0, unitCost: 0 });
    ensureSingleBlankExtra(sequence);
    pricingSaved = false;
    renderPricing(sequence);
}

function updatePricingLine(id, field, value){
    const sequence = getSelectedSequence();
    const lines = getPricingLines(sequence);

    pricingBySequence[sequence.id] = lines.map(line => {
        if (line.id !== id) return line;
        if (field === "qty" || field === "unitCost"){
            return { ...line, [field]: Number(value || 0) };
        }
        return { ...line, [field]: value };
    });

    ensureSingleBlankExtra(sequence);

    pricingSaved = false;
    renderPricing(sequence);
}

function savePricingSet(){
    pricingSaved = true;
    renderPricing(getSelectedSequence());
}

function renderPricing(sequence){
    const lines = getPricingLines(sequence);
    const mandatoryLabels = ["Vans", "Drivers / Foreman", "Crew", "Mileage", "Consumables", "Cartons", "Export Wrap", "Nights Out"];
    const optionalChoices = ["Custom", "Handyman Rate", "Parking / Parking Admin Fees", "Hoist / Crane", "Ferry", "Crating"];

    const mandatoryLines = lines.filter(line => mandatoryLabels.includes(line.label));
    const extraLines = lines.filter(line => !mandatoryLabels.includes(line.label));
    const usedExtras = extraLines.filter(line => line.label && line.label !== "");
    const blankExtra = extraLines.find(line => !line.label || line.label === "");
    const extrasToRender = blankExtra ? [...usedExtras, blankExtra] : usedExtras;

    const grid = document.getElementById("pricingGrid");
    grid.innerHTML = `
        ${mandatoryLines.map((line, index) => `
            <div class="pricing-row">
                <div>
                    <label class="mini-label">Mandatory Cost ${index + 1}</label>
                    <input class="field readonly" readonly value="${escapeAttr(line.label)}" />
                </div>
                <div></div>
                <div>
                    <label class="mini-label">Qty</label>
                    <input type="number" min="0" step="0.01" class="field" value="${line.qty}" oninput="updatePricingLine('${line.id}','qty',this.value)" />
                </div>
                <div>
                    <label class="mini-label">Unit Cost</label>
                    <input type="number" min="0" step="0.01" class="field" value="${line.unitCost}" oninput="updatePricingLine('${line.id}','unitCost',this.value)" />
                </div>
                <div>
                    <label class="mini-label">Line Total</label>
                    <input class="field readonly" readonly value="${money(lineTotal(line))}" />
                </div>
            </div>
        `).join("")}

        ${extrasToRender.map((line) => `
            <div class="pricing-row">
                <div>
                    <label class="mini-label">Select Extra Cost</label>
                    <select class="field" onchange="updatePricingLine('${line.id}','label',this.value)">
                        <option value="" ${line.label === "" ? "selected" : ""}>Select extra cost</option>
                        ${optionalChoices.map(opt => `<option value="${opt}" ${opt === line.label ? "selected" : ""}>${opt}</option>`).join("")}
                    </select>
                </div>
                <div>
                    <label class="mini-label">Custom Label</label>
                    <input class="field" value="${escapeAttr(line.customLabel || "")}" ${line.label === "Custom" ? "" : "readonly"} oninput="updatePricingLine('${line.id}','customLabel',this.value)" placeholder="Use only if custom" />
                </div>
                <div>
                    <label class="mini-label">Qty</label>
                    <input type="number" min="0" step="0.01" class="field" value="${line.qty}" oninput="updatePricingLine('${line.id}','qty',this.value)" />
                </div>
                <div>
                    <label class="mini-label">Unit Cost</label>
                    <input type="number" min="0" step="0.01" class="field" value="${line.unitCost}" oninput="updatePricingLine('${line.id}','unitCost',this.value)" />
                </div>
                <div>
                    <label class="mini-label">Line Total</label>
                    <input class="field readonly" readonly value="${money(lineTotal(line))}" />
                </div>
            </div>
        `).join("")}
    `;

    const totalCosts = calcTotalCosts(sequence);
    const customerPrice = Number(document.getElementById("customerPriceInput").value || 0);
    const grossMargin = customerPrice - totalCosts;
    const grossMarginPct = customerPrice > 0 ? ((grossMargin / customerPrice) * 100) : 0;

    document.getElementById("totalCosts").textContent = money(totalCosts);
    document.getElementById("customerPriceDisplay").textContent = money(customerPrice);
    document.getElementById("grossMarginDisplay").textContent = money(grossMargin);
    document.getElementById("grossMarginSub").textContent = customerPrice > 0
        ? `${money(grossMarginPct)}% margin on sell price${pricingSaved ? " · saved" : " · unsaved changes"}`
        : `Customer price minus total costs${pricingSaved ? " · saved" : " · unsaved changes"}`;
}

function renderAll(){
    renderSequenceSelect();
    const sequence = getSelectedSequence();
    const inventorySummary = summariseInventory(sequence);
    renderResponsibilitySummary(inventorySummary);
    renderExcludedSummary(inventorySummary);
    renderSchedulePlanner(sequence);
    renderPricing(sequence);
    document.getElementById("manualExcludedNotes").value = prototypeState.manualExcludedNotes;
    document.getElementById("customerPriceInput").dispatchEvent(new Event("input"));
}

function runSmokeTests(){
    console.assert(typeof addPricingLine === "function", "addPricingLine should exist");
    console.assert(typeof renderAll === "function", "renderAll should exist");
    console.assert(typeof addScheduleRow === "function", "addScheduleRow should exist");
    const seq = getSelectedSequence();
    const lines = getPricingLines(seq);
    const blankExtras = lines.filter(line => !MANDATORY_LABELS.includes(line.label) && (!line.label || line.label === ""));
    console.assert(blankExtras.length === 1, "There should be exactly one blank extra cost row");
}

document.getElementById("sequenceSelect").addEventListener("change", (e) => {
    prototypeState.selectedSequenceId = e.target.value;
    pricingSaved = false;
    renderAll();
});
document.getElementById("manualExcludedAddBtn").addEventListener("click", addManualExcluded);
document.getElementById("manualExcludedNotes").addEventListener("input", (e) => updateManualExcludedNotes(e.target.value));
document.getElementById("addScheduleRowBtn").addEventListener("click", addScheduleRow);
document.getElementById("addPricingLineBtn").addEventListener("click", addPricingLine);
document.getElementById("savePricingBtn").addEventListener("click", savePricingSet);
document.getElementById("customerPriceInput").addEventListener("change", () => renderPricing(getSelectedSequence()));

renderAll();
runSmokeTests();
</script>
</body>
</html>
