                            <input id="transitMinutes" type="number" min="0" max="59" class="field" value="30" oninput="renderAll()" />
                        </div>
                    </div>
                </div>

                <div class="section-block">
    <div class="section-title">Volume Inputs</div>
    <div class="grid-2">
        <div>
            <label class="mini-label">Furniture Volume (CUFT)</label>
            <div id="furnitureVolDisplay" class="field" style="background:#f8fafc;">0</div>
        </div>
        <div>
            <label class="mini-label">Loft Effects Volume (CUFT)</label>
            <input id="loftVol" type="number" min="0" class="field" value="0" oninput="renderAll()" />
        </div>
        <div>
            <label class="mini-label">Loading Rate (CUFT / Man-Hour)</label>
            <input id="loadRate" type="number" min="1" class="field" value="125" oninput="renderAll()" />
        </div>
        <div>
