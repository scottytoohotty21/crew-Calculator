<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Photon Packing, Loading & Unloading Lab</title>
<style>
:root{
    --bg:#f1f5f9;
    --card:#ffffff;
    --navy:#0f172a;
    --navy-2:#1e293b;
    --blue:#3b82f6;
    --blue-2:#2563eb;
    --blue-50:#eff6ff;
    --slate-50:#f8fafc;
    --slate-100:#f1f5f9;
    --slate-200:#e2e8f0;
    --slate-300:#cbd5e1;
    --slate-400:#94a3b8;
    --slate-500:#64748b;
    --slate-700:#334155;
    --green-50:#f0fdf4;
    --green-200:#bbf7d0;
    --green-800:#166534;
    --amber-50:#fff7ed;
    --amber-200:#fed7aa;
    --amber-800:#c2410c;
    --red-50:#fef2f2;
    --red-200:#fecaca;
    --red-800:#b91c1c;
    --shadow:0 10px 30px rgba(15,23,42,0.08);
}

*{box-sizing:border-box;}
body{
    margin:0;
    padding:18px;
    background:var(--bg);
    font-family:Inter,Segoe UI,Arial,sans-serif;
    color:var(--navy);
}
button,input,select{font:inherit;}
.shell{max-width:1280px;margin:0 auto;}
.topbar{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:16px;}
.brand{display:flex;align-items:center;gap:12px;}
.logo-circle{
    width:34px;height:34px;border-radius:999px;background:var(--navy);
    border:2px solid #ef4444;display:flex;align-items:center;justify-content:center;
}
.logo-inner{width:10px;height:10px;border-radius:999px;background:#ef4444;box-shadow:0 0 10px rgba(239,68,68,0.6);}
.brand-title{font-size:28px;font-weight:900;line-height:1;text-transform:uppercase;letter-spacing:-0.05em;margin:0;}
.brand-sub{font-size:10px;font-weight:900;color:var(--blue);text-transform:uppercase;letter-spacing:.22em;margin-top:4px;}
.status-pill{
    border:1px solid var(--slate-300);background:var(--card);border-radius:999px;padding:8px 12px;
    font-size:10px;font-weight:900;text-transform:uppercase;color:var(--slate-500);white-space:nowrap;
}
.layout{display:grid;grid-template-columns:430px 1fr;gap:16px;align-items:start;}
.panel{
    background:var(--card);border:1px solid var(--slate-200);border-radius:20px;box-shadow:var(--shadow);overflow:hidden;
}
.panel-head{background:var(--navy);padding:14px 16px;border-bottom:1px solid var(--navy-2);}
.panel-title{color:#fff;font-size:12px;font-weight:900;text-transform:uppercase;}
.panel-subtitle{color:#93c5fd;font-size:10px;font-weight:800;text-transform:uppercase;margin-top:4px;}
.panel-body{padding:16px;}
.section-block{border:1px solid var(--slate-200);border-radius:16px;padding:14px;background:var(--slate-50);}
.section-block + .section-block{margin-top:14px;}
.section-title{font-size:11px;font-weight:900;text-transform:uppercase;color:var(--navy);margin-bottom:12px;}
.mini-label{display:block;font-size:10px;font-weight:900;color:var(--slate-500);text-transform:uppercase;margin-bottom:6px;letter-spacing:.02em;}
.field{
    width:100%;border:1.5px solid var(--slate-300);border-radius:10px;padding:11px 12px;
    font-size:14px;font-weight:700;outline:none;background:#fff;color:var(--navy);
}
.field:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(59,130,246,0.08);}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.summary-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;}
.summary-card{background:#fff;border:1px solid var(--slate-200);border-radius:16px;padding:16px;min-height:128px;}
.summary-label{font-size:10px;font-weight:900;text-transform:uppercase;color:var(--slate-400);margin-bottom:8px;line-height:1.35;}
.summary-value{font-size:30px;font-weight:900;line-height:1;color:var(--navy);}
.summary-sub{font-size:10px;font-weight:800;text-transform:uppercase;color:var(--slate-500);margin-top:8px;line-height:1.35;}
.note-card{
    background:var(--blue-50);border:1px solid #bfdbfe;color:#1d4ed8;border-radius:14px;padding:12px 14px;
    font-size:11px;font-weight:800;text-transform:uppercase;line-height:1.45;
}
.info-card{background:#fff;border:1px solid var(--slate-200);border-radius:16px;padding:14px;}
.info-head{font-size:10px;font-weight:900;text-transform:uppercase;color:var(--slate-400);margin-bottom:8px;}
.info-body{font-size:12px;font-weight:700;color:var(--slate-700);line-height:1.55;}
.footer-note{margin-top:12px;font-size:10px;font-weight:800;text-transform:uppercase;color:var(--slate-400);line-height:1.45;}
.schedule-shell{margin-top:12px;border:1px solid var(--slate-200);border-radius:16px;padding:14px;background:var(--slate-50);}
.schedule-toolbar{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:12px;flex-wrap:wrap;}
.schedule-title{font-size:10px;font-weight:900;text-transform:uppercase;color:var(--slate-400);}
.schedule-btn{height:38px;border-radius:10px;border:1px solid var(--slate-300);background:#fff;color:var(--slate-700);padding:0 14px;font-size:11px;font-weight:900;text-transform:uppercase;cursor:pointer;}
.schedule-list{display:grid;gap:12px;}
.schedule-row{border:1px solid var(--slate-200);border-radius:14px;background:#fff;padding:12px;}
.schedule-row-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:10px;}
.schedule-row-title{font-size:11px;font-weight:900;text-transform:uppercase;color:var(--navy);}
.schedule-remove{height:32px;border-radius:8px;border:1px solid var(--red-200);background:var(--red-50);color:var(--red-800);padding:0 10px;font-size:10px;font-weight:900;text-transform:uppercase;cursor:pointer;}
.schedule-grid{display:grid;grid-template-columns:1.2fr 1.2fr .8fr .8fr;gap:10px;}
.validation-list{display:grid;gap:8px;margin-top:12px;}
.validation-item{border-radius:12px;padding:10px 12px;font-size:11px;font-weight:800;text-transform:uppercase;line-height:1.4;}
.validation-ok{background:var(--green-50);border:1px solid var(--green-200);color:var(--green-800);}
.validation-warn{background:var(--amber-50);border:1px solid var(--amber-200);color:var(--amber-800);}
.validation-error{background:var(--red-50);border:1px solid var(--red-200);color:var(--red-800);}
@media (max-width: 980px){
    .layout{grid-template-columns:1fr;}
    .summary-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
}
@media (max-width: 760px){
    .schedule-grid{grid-template-columns:1fr 1fr;}
}
@media (max-width: 680px){
    body{padding:12px;}
    .summary-grid,.grid-2,.schedule-grid{grid-template-columns:1fr;}
    .topbar{align-items:flex-start;flex-direction:column;}
}
</style>
</head>
<body>
<div class="shell">
    <div class="topbar">
        <div class="brand">
            <div class="logo-circle"><div class="logo-inner"></div></div>
            <div>
                <div class="brand-title">Photon</div>
                <div class="brand-sub">Packing, Loading & Unloading Lab</div>
            </div>
        </div>
        <div class="status-pill">Sequence Ready · Separate Packing / Loading / Unloading</div>
    </div>

    <div class="layout">
        <div class="panel">
            <div class="panel-head">
                <div class="panel-title">Inputs</div>
                <div class="panel-subtitle">Manual for now, ready to be fed from the previous app tab later</div>
            </div>
            <div class="panel-body">
                <div class="section-block">
    <div class="section-title">Sequence</div>
    <div>
        <label class="mini-label">Sequence</label>
        <div id="sequenceLabelDisplay" class="field" style="background:#f8fafc;">—</div>
    </div>
</div>
                
                

                <div class="section-block">
                    <div class="section-title">Transit Time</div>
                    <div class="grid-2">
                        <div>
                            <label class="mini-label">Transit Hours</label>
                            <input id="transitHours" type="number" min="0" class="field" value="0" oninput="renderAll()" />
                        </div>
                        <div>
