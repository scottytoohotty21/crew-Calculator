    return getAdditionalCostLines(sequence).reduce((sum, line) => {
        if (!line.label) return sum;
        return sum + additionalLineTotal(line);
    }, 0);
}

function getCommercialTotals(sequence){
    const coreCosts = getPricingLines(sequence).reduce((sum, line) => sum + lineTotal(line), 0);
    const additionalCosts = calcAdditionalCostsTotal(sequence);
    const totalCostBase = coreCosts;
    const customerPrice = Number(document.getElementById("customerPriceInput")?.value || 0);
    const grossMargin = customerPrice - totalCostBase;
    const grossMarginPct = customerPrice > 0 ? ((grossMargin / customerPrice) * 100) : 0;

    return {
        coreCosts,
        additionalCosts,
        totalCostBase,
        customerPrice,
        grossMargin,
        grossMarginPct
    };
}

