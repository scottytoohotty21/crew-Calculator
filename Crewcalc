    function getPackModeLabel(packOption){
      if (packOption === "none") return "No";
      if (packOption === "cg") return "CG";
      return "Full";
    }

    function getIncludedKeys(packOption){
      if (packOption === "none") return [];
      if (packOption === "cg") return ["cg"];
      return ["ap", "cg", "books", "linen", "wr"];
    }

    function buildState(){
     const sequenceExample = getText("sequenceExample") || "direct-no-pack";
const exampleConfig = getSequenceExampleConfig(sequenceExample);
const sequenceType = exampleConfig.sequenceType;
const packMode = exampleConfig.packMode;

const travelDepotToCollection = getNum("travelDepotToCollection");
const travelCollectionToDelivery = getNum("travelCollectionToDelivery");
const travelDeliveryToDepot = getNum("travelDeliveryToDepot");

      return {
        label: getText("scenarioLabel"),
        sequenceType: sequenceType,
        loadingVariant: getText("loadingVariant") || "standard",
        workingDayHours: getNum("workingDayHours") || 10,
        dayBufferMinutes: getNum("dayBufferMinutes") || 30,

        furnitureVol: getNum("furnitureVol"),
        loftVol: getNum("loftVol"),
        unloadRate: getNum("unloadRate") || 132,

       sequenceExample: sequenceExample,
packOption: packMode,
        qty: {
          ap: getNum("qty_ap"),
          cg: getNum("qty_cg"),
          books: getNum("qty_books"),
          linen: getNum("qty_linen"),
          wr: getNum("qty_wr")
        },

        travel: {
          depotToCollection: travelDepotToCollection,
          collectionToDelivery: sequenceType === "into-store" ? 0 : travelCollectionToDelivery,
          deliveryToDepot: travelDeliveryToDepot
        },

        special: {
          beds: getNum("svc_beds"),
          bunk: getNum("svc_bunk"),
          customMinutes: getNum("svc_custom_minutes"),
          customNote: getText("svc_custom_note"),
          upright: getNum("svc_upright"),
          grand: getNum("svc_grand"),
          clock: getNum("svc_clock"),
          appliance: getNum("svc_appliance"),
          crate: getNum("svc_crate"),
          dismantle: getNum("svc_dismantle")
        },

        exportWrapVol: getNum("exportWrapVol"),
        plannerRows: plannerRows.slice()
      };
    }

    function calcPacking(state){
      const includedKeys = getIncludedKeys(state.packOption);

      const packHours = Object.keys(BOX_RATES).reduce(function(sum, key){
        const qty = state.qty[key] || 0;
        if (!includedKeys.includes(key)) return sum;
        return sum + (qty / BOX_RATES[key]);
      }, 0);

      return {
        packHours: round2(packHours),
        packDays: round1(packHours / 8)
      };
    }

    function calcBoxVolume(state){
      return Object.keys(state.qty).reduce(function(sum, key){
        return sum + ((state.qty[key] || 0) * (BOX_VOLUMES[key] || 0));
      }, 0);
    }

    function calcSpecialLabour(state){
      const includedBeds = 2;
      const includedExportWrapVol = 50;

      const extraBeds = Math.max(0, state.special.beds - includedBeds);
      const extraExportWrapVol = Math.max(0, state.exportWrapVol - includedExportWrapVol);

      const loadMinutes =
        (extraBeds * 15) +
        (state.special.dismantle * 15) +
        (state.special.bunk * 30) +
        (state.special.customMinutes > 0 ? state.special.customMinutes : 0) +
        (state.special.upright * 25) +
        (state.special.grand * 60) +
        (state.special.clock * 30) +
        (state.special.appliance * 30) +
        (state.special.crate * 15) +
        ((state.loftVol / 100) * 20) +
        ((extraExportWrapVol / 100) * 25);

      const unloadMinutes =
        state.sequenceType === "into-store"
          ? 0
          : (
              (extraBeds * 15) +
              (state.special.bunk * 30) +
              (state.special.customMinutes > 0 ? state.special.customMinutes : 0) +
              (state.special.upright * 25) +
              (state.special.grand * 60) +
              (state.special.clock * 30) +
              (state.special.appliance * 30) +
              (state.special.crate * 15)
            );

      return {
        specialHours: round2((loadMinutes + unloadMinutes) / 60),
        loadSideHours: round2(loadMinutes / 60),
        unloadSideHours: round2(unloadMinutes / 60),
        breakdown: {
          beds: round2((extraBeds * 30) / 60),
          dismantle: round2((state.special.dismantle * 15) / 60),
          bunk: round2((state.special.bunk * 60) / 60),
          custom: round2(((state.special.customMinutes > 0 ? state.special.customMinutes * 2 : 0)) / 60),
          upright: round2((state.special.upright * 50) / 60),
          grand: round2((state.special.grand * 120) / 60),
          clock: round2((state.special.clock * 60) / 60),
          appliance: round2((state.special.appliance * 60) / 60),
          crate: round2((state.special.crate * 30) / 60),
          loft: round2(((state.loftVol / 100) * 20) / 60),
          exportWrap: round2(((extraExportWrapVol / 100) * 25) / 60),
          includedBeds: includedBeds,
          includedExportWrapVol: includedExportWrapVol
        }
      };
    }

    function getVariantMultiplier(state){
      if (state.loadingVariant === "slow") return 0.8;
      return 1;
    }

    function calcDomesticLoadHours(volume, men, variantMultiplier){
      if (men <= 0 || volume <= 0) return 0;

      const firstBandHours = 4 * men;
      const firstBandVolume = firstBandHours * 125 * variantMultiplier;

      if (volume <= firstBandVolume){
        return volume / (125 * variantMultiplier);
      }

      const remainingVolume = volume - firstBandVolume;
      const secondBandRate = 54 * variantMultiplier;

      return firstBandHours + (remainingVolume / secondBandRate);
    }

    function calcSequenceLoadHours(state, totalVolume, men){
      const variantMultiplier = getVariantMultiplier(state);

      if (state.sequenceType === "domestic"){
        return round2(calcDomesticLoadHours(totalVolume, men, variantMultiplier));
      }

      if (state.sequenceType === "into-store"){
        const rate = 66 * variantMultiplier;
        return round2(totalVolume / (rate * Math.max(1, men) / Math.max(1, men)));
      }

      if (state.sequenceType === "ex-store"){
        const rate = 125 * variantMultiplier;
        return round2(totalVolume / (rate * Math.max(1, men) / Math.max(1, men)));
      }

      return 0;
    }

    function calcCrewBasedLoadHours(state, totalVolume){
      const totalMen = getPlannerEffectiveMenForTask(state.plannerRows, ["Load", "Pack and Load", "Load and Deliver", "Load and Travel"]);
      if (totalMen <= 0) return 0;

      if (state.sequenceType === "domestic"){
        return round2(calcDomesticLoadHours(totalVolume, totalMen, getVariantMultiplier(state)));
      }

      const ratePerMan =
        state.sequenceType === "into-store"
          ? 66 * getVariantMultiplier(state)
          : 125 * getVariantMultiplier(state);

      return round2(totalVolume / (ratePerMan * totalMen));
    }

    function calcCrewBasedUnloadHours(state, totalVolume){
      if (state.sequenceType === "into-store") return 0;

      const totalMen = getPlannerEffectiveMenForTask(state.plannerRows, ["Unload", "Load and Deliver", "Deliver and Crew Return"]);
      if (totalMen <= 0) return 0;

      return round2(totalVolume / (state.unloadRate * totalMen));
    }

    function getPlannerEffectiveMenForTask(rows, taskNames){
      const groupMap = {};

      rows.forEach(function(row){
        if (!taskNames.includes(row.task)) return;
        if (!groupMap[row.groupId]) groupMap[row.groupId] = 0;
        groupMap[row.groupId] = Math.max(groupMap[row.groupId], Number(row.men || 0));
      });

      return Object.values(groupMap).reduce(function(sum, value){
        return sum + Number(value || 0);
      }, 0);
    }

    function calcPlannerCapacityHours(rows){
      let pack = 0;
      let load = 0;
      let unload = 0;

      rows.forEach(function(row){
        const capacity = Number(row.men || 0) * Number(row.hours || 0);

        if (row.task === "Pack") pack += capacity;
        if (row.task === "Load") load += capacity;
        if (row.task === "Unload") unload += capacity;
        if (row.task === "Pack and Load"){
          pack += capacity / 2;
          load += capacity / 2;
        }
        if (row.task === "Load and Deliver" || row.task === "Load and Travel"){
          load += capacity;
        }
        if (row.task === "Deliver and Crew Return"){
          unload += capacity;
        }
      });

      return {
        pack: round2(pack),
        load: round2(load),
        unload: round2(unload)
      };
    }

    function calcTravelHours(state){
      const totalMinutes =
        Number(state.travel.depotToCollection || 0) +
        Number(state.travel.collectionToDelivery || 0) +
        Number(state.travel.deliveryToDepot || 0);

      return {
        totalMinutes: totalMinutes,
        totalHours: round2(totalMinutes / 60)
      };
    }

    function calcTotalDayHours(packing, loadHours, unloadHours, special, travel, state){
  const bufferHours = round2((Number(state.dayBufferMinutes || 0)) / 60);

  const total =
    Number(packing.packHours || 0) +
    Number(loadHours || 0) +
    Number(unloadHours || 0) +
    Number(special.loadSideHours || 0) +
    Number(special.unloadSideHours || 0) +
    Number(travel.totalHours || 0) +
    bufferHours;

  const overtimeHours = Math.max(0, total - Number(state.workingDayHours || 0));

  return {
    totalHours: round2(total),
    bufferHours: bufferHours,
    overtimeHours: round2(overtimeHours)
  };
}

    function assessScenario(state, results){
      const reasons = [];
      const warnings = [];
      let red = false;
      let amber = false;

      if (!state.sequenceType){
        red = true;
        reasons.push("Sequence type missing");
      }

      if (state.plannerRows.length === 0){
        red = true;
        reasons.push("No planner rows added");
      }

      const hasLoadCrew = getPlannerEffectiveMenForTask(state.plannerRows, ["Load", "Pack and Load", "Load and Deliver", "Load and Travel"]) > 0;
      if (!hasLoadCrew){
        red = true;
        reasons.push("No crew allocated to loading");
      }

      if (state.sequenceType !== "into-store"){
        const hasUnloadCrew = getPlannerEffectiveMenForTask(state.plannerRows, ["Unload", "Load and Deliver", "Deliver and Crew Return"]) > 0;
        if (!hasUnloadCrew){
          red = true;
          reasons.push("No crew allocated to unloading / delivery side");
        }
      }

      if (results.totalDay.totalHours > state.workingDayHours + 1){
  red = true;
  reasons.push("Total day exceeds the standard working day by more than 1 hour");
} else if (results.totalDay.totalHours > state.workingDayHours){
  amber = true;
  warnings.push("Schedule requires overtime above the standard 9.5 hour day");
} else if (results.totalDay.totalHours > state.workingDayHours - 0.5){
  amber = true;
  warnings.push("Schedule is very tight against the standard 9.5 hour day");
}

      if (state.loadingVariant === "slow"){
        amber = true;
        warnings.push("Slow loading variant applied");
      }

      if (state.sequenceType === "into-store"){
        warnings.push("Into store skips unloading and delivery-leg travel");
      }

      if (results.loadHours > results.capacity.load + 0.01){
        red = true;
        reasons.push("Planned loading capacity is below calculated loading requirement");
      } else if (results.loadHours > results.capacity.load - 1){
        amber = true;
        warnings.push("Loading capacity is tight");
      }

      if (state.sequenceType !== "into-store"){
        if (results.unloadHours > results.capacity.unload + 0.01){
          red = true;
          reasons.push("Planned unloading capacity is below calculated unloading requirement");
        } else if (results.unloadHours > results.capacity.unload - 1){
          amber = true;
          warnings.push("Unloading capacity is tight");
        }
      }

      if (results.packing.packHours > results.capacity.pack + 0.01 && results.packing.packHours > 0){
        amber = true;
        warnings.push("Packing requirement exceeds pure pack capacity");
      }

      let status = "green";
      let label = "🟢 Green — Within Normal Rules";

      if (red){
        status = "red";
        label = "🔴 Red — Manual Review Required";
      } else if (amber){
        status = "amber";
        label = "🟠 Amber — Workable but Tight";
      }

      const finalReasons = red ? reasons : warnings.length ? warnings : ["Schedule fits comfortably within current rules"];

      return {
        status,
        label,
        reasons: finalReasons
      };
    }

    function renderAssessment(assessment){
      const statusWrap = document.getElementById("assessmentStatus");
      const reasonsWrap = document.getElementById("assessmentReasons");

      if (!statusWrap || !reasonsWrap) return;

      const className =
        assessment.status === "red"
          ? "status-chip status-red"
          : assessment.status === "amber"
            ? "status-chip status-amber"
            : "status-chip status-green";

      statusWrap.innerHTML = `<div class="${className}">${assessment.label}</div>`;

      reasonsWrap.innerHTML = assessment.reasons.map(function(reason){
        return `<div class="document-line">${reason}</div>`;
      }).join("");
    }

    function renderValidation(results, assessment){
      const wrap = document.getElementById("validationList");
      if (!wrap) return;

      const items = [];

      items.push({
        type: assessment.status === "red" ? "error" : assessment.status === "amber" ? "warn" : "ok",
